# clang-21 + libc++ + ASan/UBSan — the fork-comment fuzz/security gate (canon→eidos parse path).
#
# libc++ (NOT libstdc++) is now MANDATORY: post-1.5.1-unwrap the parse graph (canon/diff/engine)
# are C++23 modules that `import std`, and clang's std module ships ONLY with libc++-21 — a
# clang+libstdc++ build CANNOT compile `import std` (it ICE/errors in libstdc++'s std.cc:
# "cannot befriend target of using declaration"). libFuzzer (-fsanitize=fuzzer, added by the
# harness TARGET only — it provides main) links fine against libc++. -fno-sanitize-recover=all →
# any UB aborts (gate fails). Build tools stay uninstrumented via malf's clean build-context
# (auto when -fsanitize present). The cross-build-determinism leg now also exercises cross-stdlib
# (gcc-release/libstdc++ ≡ clang-asan/libc++) — a free strengthening of the byte-identity check.
# Requires clang-21 + libc++-21-dev + libc++abi-21-dev (apt.llvm.org) + the libc++.modules.json
# symlink bridge (see linux-clang21-libcxx-release — same import-std prerequisite).
[settings]
arch=x86_64
build_type=Debug
compiler=clang
compiler.version=21
compiler.cppstd=gnu23
compiler.libcxx=libc++
os=Linux

[buildenv]
CC=clang-21
CXX=clang++-21

[conf]
tools.build:cflags=["-O1", "-g", "-march=x86-64-v2", "-fno-omit-frame-pointer", "-fsanitize=address,undefined", "-fno-sanitize-recover=all"]
tools.build:cxxflags=["-O1", "-g", "-march=x86-64-v2", "-fno-omit-frame-pointer", "-fsanitize=address,undefined", "-fno-sanitize-recover=all", "-stdlib=libc++"]
tools.build:exelinkflags=["-fsanitize=address,undefined", "-stdlib=libc++"]
tools.build:sharedlinkflags=["-fsanitize=address,undefined", "-stdlib=libc++"]
# Editable build-dir keying ([[malf-build-type-isolation]]): the profile carries the keyed
# build dir so a RAW `conan create --profile <this>` (no malf env) resolves an editable dep's
# matching-profile build tree — closing the cross-stdlib editable .a contamination. malf still
# sets MALF_EDITABLE_BUILD_DIR (takes precedence; covers sanitizer profiles).
user.malf:editable_build_dir=build-clang21-asan
