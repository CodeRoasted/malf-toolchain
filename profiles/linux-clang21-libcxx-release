# linux-clang21-libcxx-release — clang-21 + libc++ + Release.
# The C++ modules / `import std` PoC leg: clang-21's native std module ships with **libc++-21**,
# NOT with libstdc++ (Gate A proven green 2026-06-04). Also the cross-stdlib determinism DIAGONAL —
# gcc-15/libstdc++ ≡ clang-21/libc++ must be byte-identical (technical_docs/adr/0015-cxx-named-modules-policy.md) —
# and the dev-default TARGET for the workspace libc++ flip (migration track, §6/§7).
# Determinism-relevant flags (-O3 -march=x86-64-v2, gnu23) MIRROR coderoast-security/linux-gcc15-release
# so the diagonal is flag-comparable; -stdlib=libc++ is inherent to the libc++ leg.
# As the DEV DEFAULT it uses the UNKEYED base conan cache (.conan2 — _malf_profile_key -> "");
# its BUILD TREES are profile-named like every other leg (build-clang21-libcxx-release/ via
# _malf_build_key), so no leg ever squats on a bare build/.
# Requires clang-21 + libc++-21-dev + libc++abi-21-dev (LLVM apt; installed 1:21.1.8, exact-match).
# IMPORT STD PREREQUISITE (every dev box + CI): libc++-21's libc++.modules.json carries a relative
# source-path that CMake misresolves to /lib/share/libc++/v1 (a packaging bug), so any libc++ build with
# CXX_MODULE_STD ON fails. Bridge it once:
#     sudo mkdir -p /usr/lib/share && sudo ln -sfn /usr/lib/llvm-21/share/libc++ /usr/lib/share/libc++
# (technical_docs/adr/0015-cxx-named-modules-policy.md / [[import-std-on-server]]).
[settings]
arch=x86_64
build_type=Release
compiler=clang
compiler.version=21
compiler.cppstd=gnu23
compiler.libcxx=libc++
os=Linux

[buildenv]
CC=clang-21
CXX=clang++-21

[conf]
# -stdlib=libc++ is implied by libcxx=libc++; explicit on compile + link for robustness.
tools.build:cflags=["-O3", "-march=x86-64-v2"]
tools.build:cxxflags=["-O3", "-march=x86-64-v2", "-stdlib=libc++"]
tools.build:exelinkflags=["-stdlib=libc++"]
tools.build:sharedlinkflags=["-stdlib=libc++"]
# Editable build-dir keying ([[malf-build-type-isolation]]): the profile carries the keyed
# build dir so a RAW `conan create --profile <this>` (no malf env) resolves an editable dep's
# matching-profile build tree — closing the cross-stdlib editable .a contamination. malf still
# sets MALF_EDITABLE_BUILD_DIR (takes precedence; covers sanitizer profiles).
user.malf:editable_build_dir=build-clang21-libcxx-release
