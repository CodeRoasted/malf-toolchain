# clang-21 + MemorySanitizer (uninitialized-read detection) — HEAVY / SEPARATE / PHASE-LAST.
#
# ⚠ SPEC, NOT YET BUILDABLE. MSan requires EVERY linked object instrumented, INCLUDING the
# C++ standard library — libstdc++ cannot be MSan-instrumented, so MSan mandates an
# MSan-instrumented libc++, AND the ENTIRE conan dependency graph (openssl, libcurl, simdjson,
# fmt, spdlog, zlib, …) rebuilt FROM SOURCE under MSan (conan-center ships none). Real risk: a
# dep that won't build under MSan. This is a parallel toolchain; do NOT block V1 on it (ASan +
# UBSan + libFuzzer cover the parse path). See the toolchain status note.
#
# PREREQUISITE (one-time): build LLVM 'runtimes' (libc++ + libc++abi + libunwind) with
# -fsanitize=memory, e.g. into /opt/llvm-msan, then append to the [conf] flags below:
#     -nostdinc++ -isystem /opt/llvm-msan/include/c++/v1
#     (link) -L/opt/llvm-msan/lib -Wl,-rpath,/opt/llvm-msan/lib -lc++ -lc++abi
# Until that exists this profile builds against the system (non-instrumented) libc++ and MSan
# will report false positives from inside the stdlib — so it is intentionally left incomplete.
[settings]
arch=x86_64
build_type=Debug
compiler=clang
compiler.version=21
compiler.cppstd=gnu23
compiler.libcxx=libc++
os=Linux

[buildenv]
CC=clang-21
CXX=clang++-21

[conf]
# -fsanitize-memory-track-origins=2 gives the allocation origin of an uninitialized read.
# (Append the MSan-libc++ -isystem/-L/-rpath from the PREREQUISITE block above before use.)
tools.build:cflags=["-O1", "-g", "-fno-omit-frame-pointer", "-fsanitize=memory", "-fsanitize-memory-track-origins=2", "-fno-sanitize-recover=all"]
tools.build:cxxflags=["-O1", "-g", "-fno-omit-frame-pointer", "-fsanitize=memory", "-fsanitize-memory-track-origins=2", "-fno-sanitize-recover=all", "-stdlib=libc++"]
tools.build:exelinkflags=["-fsanitize=memory", "-stdlib=libc++"]
tools.build:sharedlinkflags=["-fsanitize=memory", "-stdlib=libc++"]
# Editable build-dir keying ([[malf-build-type-isolation]]): the profile carries the keyed
# build dir so a RAW `conan create --profile <this>` (no malf env) resolves an editable dep's
# matching-profile build tree — closing the cross-stdlib editable .a contamination. malf still
# sets MALF_EDITABLE_BUILD_DIR (takes precedence; covers sanitizer profiles).
user.malf:editable_build_dir=build-clang21-msan
