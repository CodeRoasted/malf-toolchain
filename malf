cmd_profiles() {
    echo "malf build profiles (registry: malf/profiles/) — use: malf build <subdir> --profile <name>"
    local seen=" " d f n desc
    for d in "$MALF_DIR/profiles" "$MALF_DIR"; do
        [[ -d "$d" ]] || continue
        for f in "$d"/linux-*; do
            [[ -f "$f" ]] || continue
            n="$(basename "$f")"
            case "$seen" in *" $n "*) continue ;; esac
            seen="$seen$n "
            desc="$(grep -m1 -E '^#' "$f" 2>/dev/null | sed 's/^#[[:space:]]*//')"
            printf "  %-24s %s\n" "$n" "$desc"
        done
    done
    echo "  (--asan == --profile $MALF_ASAN_PROFILE)"
}

# Print the build directory for a target under the active profile (build-type-keyed). Lets
# scripts locate built binaries without hardcoding build/<pkg> (which breaks under --asan etc.):
#   "$(malf bin-dir --asan fuzz)/parse_fuzzer"
cmd_bin_dir() {
    local subdir=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --debug)   MALF_CONFIG="Debug" ;;
            --release) MALF_CONFIG="Release" ;;
            --profile) shift; _malf_apply_profile "$1" ;;
            --asan)    _malf_apply_profile "$MALF_ASAN_PROFILE" ;;
            *)         subdir="$1" ;;
        esac
        shift
    done
    _malf_build_dir "$(_malf_resolve_target "$subdir")"
}

# Coordinated workspace version bump: rewrite every version axis to X.Y.Z via
# pin_coherence's `bump` engine, then re-run the coherence check to prove it
# (bump rewrites exactly what the check validates → GREEN by construction). Then
# bring the conan world along with the recipes — re-sync editables to the new
# baseline across EVERY keyed cache, then surgically prune the now-stale (old-
# version) first-party binaries. Both were the recurring post-bump footgun left
# to human memory ([[editables-version-skew-after-bump]],
# [[conan-cache-hygiene-multi-home]]); chaining them in makes a bump leave a
# coherent workspace by construction, never one cache behind. Finally repackage
# the Sift Action bundle so the committed dist/index.js (the artifact action.yml
# runs) bakes in the new SIFT_VERSION rather than the previous engine.
# Tested for 1.5.0; from then on the founder owns pulling this trigger.
cmd_bump() {
    local target="${1:-}"
    if [[ ! "$target" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
        echo "malf bump: usage: malf bump X.Y.Z   (coordinated workspace version bump)" >&2
        return 1
    fi
    local pin="$MALF_WORKSPACE_ROOT/scripts/pin_coherence.py"
    if [[ ! -f "$pin" ]]; then
        echo "malf bump: $pin not found — run from a workspace checkout" >&2
        return 1
    fi
    echo "── malf bump $target — rewriting every workspace version axis ──"
    python3 "$pin" bump "$target" "$MALF_WORKSPACE_ROOT" || return 1
    echo "── verifying pin coherence at $target ──"
    python3 "$pin" "$MALF_WORKSPACE_ROOT" || return 1

    # ── Staleness hygiene, chained in so it is never left to memory. The bump above
    # rewrote every recipe to $target, but the conan world is still one version behind:
    # each keyed cache's editable registry holds orphaned OLD-version refs (conan
    # editable add refuses a recipe-mismatched version, so the prior ref lingers), and
    # the previous version's first-party BINARIES sit in every cache as inert disk bloat
    # + a footgun for any raw (non-malf) conan call. Re-sync editables to the new baseline
    # across EVERY keyed cache, THEN prune the now-stale (!= $target) first-party binaries
    # — sync first so clean stale runs against a registry already coherent at the baseline
    # it derives from the recipes. Runs BEFORE the Sift repackage so an unrelated node/npm
    # failure can never leave the conan workspace one cache behind.
    echo "── re-syncing editables to $target across every keyed cache ──"
    _malf_editables_sync || return 1
    echo "── pruning stale (!= $target) first-party packages from every cache ──"
    _malf_clean_stale || return 1

    # ── Sift Action bundle: dist/index.js is the COMMITTED artifact action.yml
    # executes (`main: dist/index.js`) and bakes SIFT_VERSION in at esbuild time.
    # The bump above rewrote only the SOURCE (src/sift-version.ts), so the bundle
    # now still downloads the PREVIOUS engine release. INV-8 parses the source and
    # the sift-action ci.yml dist-sync gate only catches the drift AFTER the fact —
    # so re-bundle here, at bump time, leaving a coherent artifact by construction
    # (the bundle is a derived axis; never trust a human to hand-sync it).
    local action_dir="$MALF_WORKSPACE_ROOT/sift-action"
    if [[ -f "$action_dir/src/sift-version.ts" ]]; then
        echo "── repackaging sift-action bundle (dist/index.js) at $target ──"
        if [[ ! -d "$action_dir/node_modules" ]]; then
            echo "malf bump: $action_dir/node_modules missing — run 'npm ci' there first;" >&2
            echo "  the bump rewrote src/sift-version.ts but cannot regenerate dist/index.js" >&2
            return 1
        fi
        ( cd "$action_dir" && npm run package ) || {
            echo "malf bump: 'npm run package' failed — dist/index.js still bakes in the old engine version" >&2
            return 1
        }
        if ! grep -q "SIFT_VERSION = \"$target\"" "$action_dir/dist/index.js"; then
            echo "malf bump: dist/index.js does not embed SIFT_VERSION = \"$target\" after repackage" >&2
            return 1
        fi
        echo "✓ sift-action bundle repackaged — dist/index.js downloads engine-v$target"
    fi
}

# Pre-cut Release Gate: forced `conan create` for EVERY released package (the
# `release: true` set in packages.yml), in dependency order, from a CLEAN EXPORT.
# Catches the conan-create-only drift class — a rotted test_package, or a sibling
# package the editable `malf test <repo>` never compiles — BEFORE the tag, not AT
# it (the v1.6.2 eidos break; [[conan-create-only-drift-at-tag]]). The released set
# is the ONE canonical source (scripts/pin_coherence.py released, from packages.yml),
# shared with the tag-time Release Gate — no second hand-maintained list to drift
# (compatibility_matrix.md § Release Gates; [[ci-vendoring-baseline-drift]]).
#
# Non-vacuity is the whole point of the gate:
#   * --build="<pkg>/*" FORCES each package from source even when a cached binary
#     exists; plain --build=missing CACHE-SKIPS it (0 compile steps → vacuous exit 0).
#   * conan create (not the editable build) is the ONLY path that exports to the
#     cache and compiles the test_package consumer smoke + a package's tests from a
#     clean export — exactly what `malf test`/editables never build.
#   * a DEDICATED, editable-FREE cache: first-party deps resolve from the cache
#     packages THIS sweep builds in dep order, never from a working-tree editable
#     (which would shadow the clean export the gate exists to exercise). The dev's
#     editable registry is untouched. Override the cache with MALF_CUT_VERIFY_CONAN_HOME
#     (CI points it at the warm dep cache so only first-party packages rebuild).
#
# Usage: malf cut-verify [pkg-name] [--profile <name>] [--list]
#   pkg-name   scope the sweep to one released package (else: the whole set)
#   --list     print the canonical released set (dep order) and exit — build nothing
cmd_cut_verify() {
    local only="" list_only=false
    # A RELEASE gate builds the way the cut SHIPS: gcc-15 / libstdc++ — the canonical
    # conan-create environment (release-publish + the conan-module action default), not
    # the dev-default clang/libc++. Overridable with --profile (e.g. a clang-only box).
    _malf_apply_profile "${MALF_CUT_VERIFY_PROFILE:-linux-gcc15-release}"
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --profile) shift; _malf_apply_profile "$1" ;;
            --list)    list_only=true ;;
            --only)    shift; only="$1" ;;
            -*)        echo "malf cut-verify: unknown option '$1'" >&2; exit 1 ;;
            *)         only="$1" ;;   # positional scope filter: a package NAME
        esac
        shift
    done

    local pin="$MALF_WORKSPACE_ROOT/scripts/pin_coherence.py"
    [[ -f "$pin" ]] || { echo "malf cut-verify: $pin not found — run from a workspace checkout" >&2; return 1; }

    # The canonical released-package list, topo-ordered (deps before dependents).
    local released
    released="$(python3 "$pin" released "$MALF_WORKSPACE_ROOT")" \
        || { echo "malf cut-verify: failed to resolve the released-package list" >&2; return 1; }

    if $list_only; then
        echo "malf cut-verify: canonical released set (packages.yml release:true, dep order):"
        printf '%s\n' "$released" | awk -F'\t' 'NF>=2 {printf "  %-30s %s\n", $1, $2}'
        return 0
    fi

    # ── Dedicated, editable-free clean-export cache (see header) ──────────────
    export CONAN_HOME="${MALF_CUT_VERIFY_CONAN_HOME:-$MALF_CONAN_HOME_BASE/cut-verify}"
    mkdir -p "$CONAN_HOME/profiles"
    _malf_sync_global_conf
    _malf_apply_profile "$MALF_PROFILE_NAME"      # re-resolve the profile INTO this cache
    _malf_install_workspace_hooks
    rm -f "$CONAN_HOME/editable_packages.json"    # CLEAN-EXPORT invariant: no editables
    # CLEAN-EXPORT invariant #2: recipes branch their cmake builddirs on MALF_EDITABLE_BUILD_DIR
    # (e.g. canon/eidos ship their OWN cmake config under lib/cmake/<pkg> with cmake_find_mode=none;
    # when the var is set they ALSO list the editable build-tree dir). A clean conan create has no
    # editable build tree, so that path is bogus and pollutes CMAKE_PREFIX_PATH → find_package fails.
    # Real CI (conan-module / release-publish) runs with it UNSET; match that exactly. _malf_apply_profile
    # exported it just above, so unset it here, after.
    unset MALF_EDITABLE_BUILD_DIR

    echo "=== malf cut-verify: forced conan create over the released set ($MALF_PROFILE_NAME) ==="
    echo "    cache: $CONAN_HOME"

    local profile_args=(
        --profile:host="$MALF_PROFILE"
        --profile:build="$MALF_BUILD_PROFILE"
        -s build_type=Release
    )

    local name path deps total=0 ok=0
    local -a failed=() skipped=()
    local -A broke=()   # name -> 1 once it failed or was skipped (blocks dependents)

    while IFS=$'\t' read -r name path deps; do
        [[ -n "$name" && -n "$path" ]] || continue
        if [[ -n "$only" && "$name" != "$only" && "$(basename "$path")" != "$only" ]]; then
            continue
        fi
        total=$((total+1))

        # SKIP (don't FAIL) a package whose first-party dep already broke — its
        # conan create would fail for a MISSING upstream, not a defect of its own.
        # Reporting it as "blocked" keeps cascade noise out of the failure list.
        local blocked="" dep
        for dep in ${deps//,/ }; do
            [[ -n "${broke[$dep]:-}" ]] && { blocked="$dep"; break; }
        done
        if [[ -n "$blocked" ]]; then
            skipped+=("$name (dep $blocked failed)")
            broke["$name"]=1
            echo "--- cut-verify: SKIP $name — upstream $blocked failed ---" >&2
            continue
        fi

        echo "::group::cut-verify [$total] conan create $name ($path)"
        # --build=missing: third-party + not-yet-built first-party deps build if absent
        #   (deps earlier in dep order are already in-cache from THIS sweep → current).
        # --build="$name/*": FORCE this package from source (kills the cache-skip).
        if conan create "$path" "${profile_args[@]}" --build=missing --build="$name/*"; then
            ok=$((ok+1)); echo "::endgroup::"
        else
            echo "::endgroup::"
            failed+=("$name"); broke["$name"]=1
            echo "::error::cut-verify FAIL — conan create $name ($path) failed" >&2
        fi
    done <<< "$released"

    echo
    if [[ $total -eq 0 ]]; then
        echo "malf cut-verify: no released package matched '$only'" >&2; return 1
    fi
    if [[ ${#failed[@]} -gt 0 ]]; then
        echo "❌ malf cut-verify: ${#failed[@]} released package(s) FAILED forced conan create: ${failed[*]}" >&2
        [[ ${#skipped[@]} -gt 0 ]] && echo "   blocked (upstream failed): ${skipped[*]}" >&2
        echo "   A failure here is a conan-create-only break (rotted test_package / sibling package) that" >&2
        echo "   'malf test' + editables never compile — fix at root BEFORE the cut. [[conan-create-only-drift-at-tag]]" >&2
        return 1
    fi
    echo "✅ malf cut-verify: all $ok released package(s) conan-create clean —"
    echo "   forced from-source rebuild + test_package, dependency order, clean export ($MALF_PROFILE_NAME)."
}

# ─── Dispatch ────────────────────────────────────────────────────────────────

# Test seam. `source`-ing malf with MALF_SOURCE_ONLY=1 stops HERE, so the pure helpers
# (_malf_profile_key, _malf_build_key, …) can be exercised without dispatching a command.
# Placed at the dispatch boundary rather than the top of the file so everything a test
# might call is already defined — the guard skips the ACTION, never the definitions.
# Nothing else reads this variable; it is inert in every real invocation.
if [[ -n "${MALF_SOURCE_ONLY:-}" ]]; then
    return 0 2>/dev/null || exit 0
fi

COMMAND="${1:-help}"
shift || true

case "$COMMAND" in
    build)            cmd_build "$@" ;;
    test)             cmd_test "$@" ;;
    lint)             cmd_lint "$@" ;;
    format)           cmd_format "$@" ;;
    commands|compile-commands) cmd_compile_commands ;;
    bench)            cmd_bench "$@" ;;
    clean)            cmd_clean "$@" ;;
    editables)        cmd_editables "$@" ;;
    profiles)         cmd_profiles ;;
    bump)             cmd_bump "$@" ;;
    cut-verify)       cmd_cut_verify "$@" ;;
    lock)             cmd_lock "$@" ;;
    sbom)             cmd_sbom "$@" ;;
    run)              cmd_run "$@" ;;
    bin-dir)          cmd_bin_dir "$@" ;;
    help|-h|--help)   cmd_help ;;
    *)
        echo "malf: unknown command '$COMMAND'" >&2
        cmd_help >&2
        exit 1
        ;;
esac
