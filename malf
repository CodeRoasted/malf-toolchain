#!/usr/bin/env bash
# malf — unified build system for coderoast C++ projects
#
# Usage:
#   malf build   [subdir] [--debug|--release|--asan|--profile <name>]
#   malf test    [subdir] [--debug|--release] [--filter PATTERN]
#   malf lint    [--all-files] [-c|--console]
#   malf format  [--check]
#   malf commands|compile-commands
#   malf bench   [subdir] [--quick] [--filter REGEX] [--compare] [--repetitions N]
#   malf clean   [build|conan|editables|stale|all]
#   malf bump    X.Y.Z
#   malf cut-verify [pkg] [--profile <name>] [--list]
#   malf run     <exe-name>
#   malf editables [list|sync]
#
# Verb semantics:
#   `build` compiles EVERYTHING — package + tests + benches (one compile
#   surface; a bench-only TU can't rot unseen). `test` runs ctest and `bench`
#   runs the bench executables, each on top of the same incremental build.
#
# Targets:
#   No arg = every package under the current dir, dependency-ordered (a
#   mono-package root degenerates to the single package). An explicit arg
#   naming a package dir = exactly that package. Build trees are package-
#   anchored (<pkg>/build-<profile-key>) — the same tree whether the package
#   is the target, a sibling's editable dep, or built from its own subfolder,
#   from any invocation directory.
#
# Workspace Dependencies:
#   Workspace packages are automatically registered as Conan editables and
#   built in dependency order. This keeps local builds fast and incremental.
#   CMakeDeps resolves concrete library files from each dependency's
#   package-anchored build tree, and header paths from each package's api/
#   directory.
#
# Run from any directory that contains a conanfile.py (or any parent of
# dirs that contain one).

set -euo pipefail

MALF_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CWD="$(pwd)"
MALF_WORKSPACE_ROOT="${MALF_WORKSPACE_ROOT:-$(cd "$MALF_DIR/.." && pwd)}"
# The dev-default toolchain (founder 2026-06-04, the clang→libc++ flip). Single
# source of truth — the profile fallback, the cache-key arm, and the build-dir
# naming below all derive from it.
# Env-overridable so a single-profile context (e.g. a CI benchmark job that vendored its
# first-party deps into the BASE cache) can make its profile THE default — which makes
# _malf_profile_key return "" (no keyed sub-cache), so the build resolves those vendored
# deps from the base cache instead of an empty keyed one. Unset → the dev default below.
MALF_DEFAULT_PROFILE="${MALF_DEFAULT_PROFILE:-linux-clang21-libcxx-release}"
MALF_AUTO_WORKSPACE_DEPS="${MALF_AUTO_WORKSPACE_DEPS:-1}"

# ─── Source-walk guards (format + lint) ──────────────────────────────────────
# Both `format` and `lint` walk the tree for source extensions and hand what
# they find to an LLVM tool. Both tools' peak memory scales with input size,
# steeply: clang-format-21 costs several HUNDRED times a file's size (measured:
# 1.3 MB -> 1.27 GB RSS, 5.4 MB -> 2.52 GB, 10.8 MB aborts past an 8 GB cap,
# 27 MB does not finish in 2 min). So ONE stray large file carrying a source
# extension — a vendored blob, a generated table, a dumped model — exhausts the
# box. Under WSL that does not OOM-kill a single process: the kernel thrashes
# the swap file until the whole distro dies (founder, 2026-07-21, `format` at
# the workspace root over a GGUF-adjacent tree).
# Two independent guards, because either alone leaves a hole:
#   size cap — keeps pathological inputs out of the tool entirely
#   address-space cap — bounds the damage when a *small* file behaves badly
# The largest real source file in this workspace is ~99 KB and a real clang-tidy
# TU peaks at ~436 MB, so both defaults sit an order of magnitude above anything
# legitimate and well below the RAM whose exhaustion kills the box.
MALF_SOURCE_MAX_FILE_KB="${MALF_SOURCE_MAX_FILE_KB:-2048}"
MALF_SOURCE_MEM_LIMIT_KB="${MALF_SOURCE_MEM_LIMIT_KB:-4194304}"
# Files per clang-format process. Bounds the blast radius of a pathological
# file to its own batch instead of the whole run; ~15 processes for this
# workspace's 713 files, so the startup cost is noise. (`lint` fans out at
# -n 1 already, so it needs no equivalent.)
MALF_FORMAT_BATCH_SIZE="${MALF_FORMAT_BATCH_SIZE:-50}"
# Directory BASENAMES (glob-matched) pruned from BOTH walks — the single
# hazard baseline, so the two commands cannot drift apart the way two
# hand-maintained exclusion lists always do. Pruned, not filtered: a
# `-not -path` test still descends into and stat-s every entry beneath the
# directory it claims to exclude.
# `.model` / `.model-build` are the explain-overlay trees: the latter holds a
# full llama.cpp checkout (thousands of TUs), the former the GGUF asset.
# Add project-specific dirs via MALF_{FORMAT,LINT}_EXCLUDE_EXTRA, not here.
MALF_SOURCE_EXCLUDE_DIRS="${MALF_SOURCE_EXCLUDE_DIRS:-build build-* .conan2 .cache .git data node_modules .venv venv third_party vendor _deps .model .model-build}"
MALF_FORMAT_EXCLUDE_EXTRA="${MALF_FORMAT_EXCLUDE_EXTRA:-}"
# `lint`'s additions are POLICY, not hazard: test_package/ and technical_docs/
# are out of lint scope, and tests/ + benchmarks/ import the heavy re-export
# aggregator BMIs that race clang's ASTReader under the parallel fan-out (see
# cmd_lint's --header-filter note).
MALF_LINT_EXCLUDE_EXTRA="${MALF_LINT_EXCLUDE_EXTRA:-test_package technical_docs tests benchmarks}"

# ─── Cache resolution ────────────────────────────────────────────────────────
# Local cache: workspace-shared .conan2 by default so sibling repos reuse the
# same internal and third-party packages. Override with CONAN_HOME when you
# explicitly need an isolated cache.
export CONAN_HOME="${CONAN_HOME:-$MALF_WORKSPACE_ROOT/.conan2}"
# Build-type isolation: CONAN_HOME is the BASE cache. Per-build-type builds get a keyed SUBDIR
# under it (_malf_use_keyed_cache, after the profile is resolved) so a sanitizer build's
# instrumented deps can never be served to a non-instrumented link — even when CI pins
# CONAN_HOME=$WORKSPACE/.conan2 (conan's package_id ignores the sanitizer cflags, so isolation
# must be by cache PATH, not package_id). The base stays the default-release cache.
MALF_CONAN_HOME_BASE="$CONAN_HOME"

# ─── Profile resolution ──────────────────────────────────────────────────────
# 1) CONAN_HOME/profiles/, 2) malf dir, 3) per-repo dir (if in a subdirectory)
_malf_profile_path() {
    # Resolve a conan profile by name to a path in the conan cache (conan create finds
    # profiles there by name). Source of truth, in order: the registry malf/profiles/,
    # a flat malf/ profile, then a per-repo profile. When a source exists we COPY it into
    # the cache EVERY time (overwrite) so a profile EDIT always propagates — the prior
    # "cache wins" shortcut silently served a stale copy after an edit (a real footgun).
    local name="${MALF_PROFILE_NAME:-$MALF_DEFAULT_PROFILE}"
    local cache_p="$CONAN_HOME/profiles/$name"
    local src
    for src in "$MALF_DIR/profiles/$name" "$MALF_DIR/$name"; do
        if [[ -f "$src" ]]; then
            mkdir -p "$CONAN_HOME/profiles"; cp -f "$src" "$cache_p"; echo "$cache_p"; return
        fi
    done
    local repo_p
    while IFS= read -r repo_p; do
        if [[ -f "$repo_p/$name" ]]; then
            mkdir -p "$CONAN_HOME/profiles"; cp -f "$repo_p/$name" "$cache_p"; echo "$cache_p"; return
        fi
    done < <(find "$MALF_WORKSPACE_ROOT" -maxdepth 1 -type d ! -name '.*' ! -path "$MALF_WORKSPACE_ROOT")
    # No in-tree source: fall back to a pre-existing cache profile (e.g. conan-detected).
    [[ -f "$cache_p" ]] && { echo "$cache_p"; return; }
    echo "malf: error: Conan profile '$name' not found in $MALF_DIR/profiles/, $MALF_DIR/, any repo dir, or $CONAN_HOME/profiles/" >&2
    exit 1
}

# Select a build profile by name (the registry: malf/profiles/<name>). Derives the build
# type FROM the profile so the cmake preset matches, and — for a sanitizer profile — points
# the BUILD context at a clean profile so build tools (m4/autoconf/cmake) are never
# instrumented (an ASan/MSan-built m4 breaks libcurl/autotools autoreconf).
_malf_apply_profile() {
    MALF_PROFILE_NAME="$1"
    MALF_PROFILE="$(_malf_profile_path)" || exit 1
    local bt
    bt="$(sed -nE 's/^[[:space:]]*build_type[[:space:]]*=[[:space:]]*([A-Za-z]+).*/\1/p' "$MALF_PROFILE" | head -n1)"
    [[ -n "$bt" ]] && MALF_CONFIG="$bt"
    # Match the actual conf FLAG lines (tools.build:...-fsanitize=...), not a comment that
    # merely mentions -fsanitize (e.g. the libc++ profile's "NOT a sanitizer profile" note).
    if grep -qE '^[[:space:]]*tools\.build:.*-fsanitize=' "$MALF_PROFILE"; then
        MALF_BUILD_PROFILE="$(MALF_PROFILE_NAME="${MALF_CLEAN_BUILD_PROFILE:-linux-gcc15-release}" _malf_profile_path)"
        MALF_IS_SANITIZER=1
    else
        MALF_BUILD_PROFILE="$MALF_PROFILE"
        MALF_IS_SANITIZER=0
    fi
    # The profile-named editable subdir, for malf's OWN build-dir logic (_malf_editable_build_dir /
    # _malf_build_dir). NOT exported: a recipe's package_info reads this env unconditionally, so a
    # CROSS-REPO CACHED dep (no editable build tree) would prepend a BOGUS build-<key> path that
    # becomes <pkg>_DIR and shadows its packaged lib/cmake config → find_package fails (the release
    # benchmark: editable target + cached cross-repo deps, bugs.md 2026-07-10). Keeping it un-exported
    # means conan never sees it → recipe LAYOUTS fall back to the profile's user.malf:editable_build_dir
    # conf (same value, every profile carries it) for the editable case, and cached deps get the clean
    # lib/cmake path. Matches the cut-verify `unset MALF_EDITABLE_BUILD_DIR` discipline.
    MALF_EDITABLE_BUILD_DIR="build-$(_malf_build_key)"
}

# ─── Build-type isolation ([[malf-build-type-isolation]]) ─────────────────────
# CONAN-CACHE isolation key from the active profile. The dev default -> "" so the
# shared base cache (.conan2) is reused; any other profile (gcc-15 ship /
# clang-libstdc++ / sanitizer / msan) -> a distinct key, so its conan packages can
# never collide with the base (an ASan-built libz.a reaching a release link, or a
# libstdc++ .a reaching a libc++ link).
#
# NOTE: this keys the CACHE only. BUILD TREES are named by _malf_build_key below,
# which names EVERY leg — the default included (build-clang21-libcxx-release/) —
# so an unnamed build/ can never be mistaken for "whichever toolchain built last".
_malf_profile_key() {
    # Dev default is clang-21 + libc++ (devXP/tooling + the cross-stdlib determinism diagonal;
    # founder 2026-06-04, the clang→libc++ flip) -> IT is the unkeyed base cache.
    # gcc-15+libstdc++ (ship + the diagonal's reference leg) and clang-21+libstdc++ are explicit
    # + keyed. Conan coexists the stdlibs by package_id (the -stdlib flag folds into it).
    case "${MALF_PROFILE_NAME:-$MALF_DEFAULT_PROFILE}" in
        $MALF_DEFAULT_PROFILE|"") echo "" ;;
        linux-*)                  echo "${MALF_PROFILE_NAME#linux-}" ;;
        *)                        echo "$MALF_PROFILE_NAME" ;;
    esac
}

# BUILD-TREE name key from the active profile: ALWAYS named, default included.
# Every leg builds into build-<key>/ (build-clang21-libcxx-release/,
# build-gcc15-release/, build-clang21-asan/, ...): the tree self-documents its
# toolchain, and the old asymmetry — the default leg squatting on a bare build/
# while the gcc leg was named — is gone.
_malf_build_key() {
    local name="${MALF_PROFILE_NAME:-$MALF_DEFAULT_PROFILE}"
    case "$name" in
        linux-*) echo "${name#linux-}" ;;
        *)       echo "$name" ;;
    esac
}

# The DEFAULT profile's build root under a directory (what .clangd's
# CompilationDatabase points at, whatever profile the CURRENT command runs).
_malf_default_build_root() {
    echo "$1/build-${MALF_DEFAULT_PROFILE#linux-}"
}

# Sync the in-tree global.conf (the source of truth) into the active CONAN_HOME, OVERWRITING when it
# differs. The profiles + hooks already re-seed every run; global.conf must too — a PERSISTENT conan
# home (the self-hosted runner) that was seeded once would otherwise SHADOW a policy change forever
# (a `package_id` mode change silently never applied → stale-binary ABI skew, superproject bugs.md
# 2026-07-10). cmp -s keeps it a no-op when already in sync.
_malf_sync_global_conf() {
    [[ -f "$MALF_DIR/global.conf" ]] || return 0
    mkdir -p "$CONAN_HOME"
    if [[ ! -f "$CONAN_HOME/global.conf" ]] || ! cmp -s "$MALF_DIR/global.conf" "$CONAN_HOME/global.conf"; then
        cp "$MALF_DIR/global.conf" "$CONAN_HOME/global.conf"
    fi
}

# Point CONAN_HOME at a build-type-keyed SUBDIR of the base, then re-seed global.conf + hooks +
# re-resolve the profiles into it. No-op for the default profile (key == "") — the load-time base
# seed stands. Call AFTER the profile is resolved (post arg-parse), BEFORE conan install.
_malf_use_keyed_cache() {
    local key; key="$(_malf_profile_key)"
    [[ -z "$key" ]] && return 0
    export CONAN_HOME="$MALF_CONAN_HOME_BASE/$key"
    mkdir -p "$CONAN_HOME/profiles"
    _malf_sync_global_conf
    # re-resolve the host + clean-build-context profiles INTO the keyed cache (paths live under
    # CONAN_HOME/profiles); preserve any explicit --debug/--release the caller set.
    local _saved_config="$MALF_CONFIG"
    _malf_apply_profile "$MALF_PROFILE_NAME"
    MALF_CONFIG="$_saved_config"
    _malf_install_workspace_hooks
}
MALF_PROFILE="$(_malf_profile_path)"
MALF_PROFILE_NAME="$(basename "$MALF_PROFILE")"
# Seed the default-path value (the default profile never goes through _malf_apply_profile). NOT
# exported — see _malf_apply_profile: conan must not inherit this (cached cross-repo deps' package_info
# would prepend a bogus build-<key> path → find_package fails); recipe layouts use the profile conf.
MALF_EDITABLE_BUILD_DIR="build-$(_malf_build_key)"
# Build-context profile (the tools that DO the building — m4, autoconf, cmake). Defaults
# to the host profile; --asan points it at a NORMAL profile so sanitizer flags never
# instrument build tools (an ASan-built m4 breaks libcurl/autotools autoreconf).
MALF_BUILD_PROFILE="${MALF_BUILD_PROFILE:-$MALF_PROFILE}"
# The profile `--asan` selects (sugar for `--profile $MALF_ASAN_PROFILE`): clang-21 +
# libstdc++ + ASan/UBSan (libFuzzer via the harness target). Requires clang-21 installed.
MALF_ASAN_PROFILE="${MALF_ASAN_PROFILE:-linux-clang21-asan}"

# ─── Conan global.conf / hooks ───────────────────────────────────────────────
# Sync the local cache's global.conf from the in-tree source of truth (overwrite-if-different).
_malf_sync_global_conf

_malf_install_workspace_hooks() {
    local hooks_dir="$CONAN_HOME/extensions/hooks"
    mkdir -p "$hooks_dir"

    local source_hook installed_hook
    while IFS= read -r source_hook; do
        installed_hook="$hooks_dir/$(basename "$source_hook")"
        if [[ ! -f "$installed_hook" ]] || ! cmp -s "$source_hook" "$installed_hook"; then
            cp "$source_hook" "$installed_hook"
        fi
    done < <(find "$MALF_WORKSPACE_ROOT" -path '*/scripts/conan_hooks/hook_*.py' | sort)
}

_malf_install_workspace_hooks

# ─── Helpers ─────────────────────────────────────────────────────────────────
_malf_pkg_ref() {
    local conanfile="$1"
    python3 -c 'import ast,pathlib,sys
tree=ast.parse(pathlib.Path(sys.argv[1]).read_text())
nodes=list(tree.body)+[n for c in tree.body if isinstance(c,ast.ClassDef) for n in c.body]
get=lambda k:next(n.value.value for n in nodes if isinstance(n,ast.Assign) and any(getattr(t,"id","")==k for t in n.targets))
print(get("name")+"/"+get("version"))' "$conanfile"
}

# All three recipe-graph queries live in malf_graph.py (one AST recipe parser,
# no conan invocation): `deps` = a target's transitive workspace requires in
# dependency order (+ the target's own test_requires as non-transitive roots);
# `all` = every workspace recipe (what `editables sync` re-registers);
# `members` = every recipe under a dir, topo-sorted member-to-member (the
# no-arg multi-package sweep order).
_malf_workspace_dep_entries() {
    local target="$1"
    local include_test_requires="${2:-1}"
    python3 "$MALF_DIR/malf_graph.py" deps "$MALF_WORKSPACE_ROOT" "$target" "$include_test_requires"
}

_malf_workspace_packages() {
    python3 "$MALF_DIR/malf_graph.py" all "$MALF_WORKSPACE_ROOT"
}

_malf_member_packages() {
    python3 "$MALF_DIR/malf_graph.py" members "$1"
}

_malf_resolve_dir() {
    # Resolve an optional subdir arg to an absolute directory (no conanfile
    # requirement — the caller decides whether it needs a package or a sweep root).
    local arg="${1:-}"
    if [[ -z "$arg" ]]; then
        echo "$CWD"
    elif [[ -d "$CWD/$arg" ]]; then
        echo "$(cd "$CWD/$arg" && pwd)"
    elif [[ -d "$arg" ]]; then
        echo "$(cd "$arg" && pwd)"
    else
        echo "malf: error: '$arg' is not a directory" >&2; exit 1
    fi
}

_malf_resolve_target() {
    # Given an optional subdir arg, return the absolute path to the dir
    # containing a conanfile.py. Errors if none found.
    local target
    target="$(_malf_resolve_dir "${1:-}")" || exit 1
    if [[ ! -f "$target/conanfile.py" ]]; then
        echo "malf: error: no conanfile.py found in $target" >&2; exit 1
    fi
    echo "$target"
}

# Resolve the verb's target — ONE package (sets MALF_TARGET, returns) or a
# dependency-ordered SWEEP over every package under the resolved dir (runs
# `malf <verb> <member> <flags…>` per member — the exact `&&`-chain semantics,
# each member a fresh process so no profile/cache/config state bleeds — and
# exits with the sweep's status).
#
# The rule, invocation-point-based:
#   * explicit arg naming a package dir (has conanfile.py)  -> that package only,
#     even when sub-recipes exist below it (the precise escape hatch, e.g.
#     `malf build .` at a root-package multi-package repo);
#   * anything else (no arg, or an arg dir without a recipe) -> sweep every
#     recipe under the dir, topo-ordered (a root-dir recipe is a member too);
#     a single found recipe degenerates to the plain single-package build.
# So a mono-package repo root, a leaf package subfolder, and `malf <verb> <pkg>`
# all behave identically — a subfolder never knows (or cares) that it sits in a
# multi-package repo, and no-arg at a multi-package root builds the whole repo.
_malf_resolve_target_or_sweep() {
    local verb="$1" arg="$2"; shift 2
    local root
    root="$(_malf_resolve_dir "$arg")" || exit 1
    if [[ -n "$arg" && -f "$root/conanfile.py" ]]; then
        MALF_TARGET="$root"; return 0
    fi
    local members=() entry ref dir
    while IFS=$'\t' read -r ref dir; do
        [[ -n "$ref" && -n "$dir" ]] && members+=("$dir")
    done < <(_malf_member_packages "$root")
    if [[ ${#members[@]} -eq 0 ]]; then
        if [[ -f "$root/conanfile.py" ]]; then
            # A recipe malf_graph could not parse a ref from — let the single-target
            # path surface the real error rather than claiming "no conanfile".
            MALF_TARGET="$root"; return 0
        fi
        echo "malf: error: no conanfile.py found in (or under) $root" >&2; exit 1
    fi
    if [[ ${#members[@]} -eq 1 ]]; then
        MALF_TARGET="${members[0]}"; return 0
    fi
    echo "=== malf $verb: ${#members[@]} packages under $root (dependency order) ==="
    local i=0 member label
    for member in "${members[@]}"; do
        i=$((i+1))
        label="${member#"$root"/}"; [[ "$member" == "$root" ]] && label="."
        echo "── malf $verb [$i/${#members[@]}] $label ──"
        if ! MALF_SWEEP=1 "$MALF_DIR/malf" "$verb" "$member" "$@"; then
            echo "malf $verb: sweep FAILED at $label ($((i-1))/${#members[@]} completed)" >&2
            exit 1
        fi
    done
    echo "=== malf $verb: all ${#members[@]} packages done ==="
    exit 0
}

_malf_build_dir() {
    # <pkg>/build-<key> — anchored at the PACKAGE, never the invocation CWD, and
    # ALWAYS profile-named (the default leg included), so an ASan tree never
    # clobbers the release one and a bare build/ can never masquerade as
    # "whichever toolchain built last". This is the SAME tree
    # _malf_editable_build_dir resolves (MALF_EDITABLE_BUILD_DIR == build-<key>):
    # one build tree per (package, profile), whether the package is built as the
    # target, as a sibling's editable dep, or from inside its own subfolder —
    # the root fix for the old "cd into a subdir -> second, inconsistent build
    # tree that links a stale dependency" footgun.
    echo "$1/build-$(_malf_build_key)"
}

_malf_preset() {
    case "${MALF_CONFIG:-Release}" in
        Debug)   echo "conan-debug" ;;
        Release) echo "conan-release" ;;
        *) echo "malf: error: unknown config ${MALF_CONFIG}" >&2; exit 1 ;;
    esac
}

# Workspace lockfile args. The lockfile lives in the MALF repo, not the superproject —
# CI checks out CodeRoasted/malf-toolchain into malf/ (see insight-eidos golden.yaml /
# release.yaml) and never checks out the superproject, so malf/ is the only tree that
# reaches BOTH the desk and every CI leg. Same reasoning that puts global.conf + profiles
# here. Absent file => no args, so a checkout without it still builds.
#
# WHY: third-party recipes require by RANGE (clickhouse-cpp -> lz4/[>=1.9.4 <2],
# libcurl -> openssl/[>=3 <4], zlib/[>=1.2.11 <2]) and conan resolves a range against the
# MUTABLE LOCAL CACHE unless --update. So the same recipe resolves differently depending on
# cache state: measured 2026-07-21, coderoast_infra_clickhouse standalone took lz4/1.10.0
# while coderoast_server — which LINKS it — took lz4/1.9.4. The openssl twin of that split
# failed loudly (version conflict, server offline); the lz4 one is silent. The lockfile makes
# the resolved graph a committed fact instead of a function of when you built.
#
# --lockfile-partial is deliberate for the DESK: the lockfile then PINS what it knows and
# lets a genuinely new dependency resolve, so adding a require does not brick every build
# until someone refreshes (that is how a lockfile gets disabled in practice). It means the
# desk lockfile pins rather than GATES. Set MALF_LOCKFILE_STRICT=1 (CI / release legs) to
# drop --lockfile-partial, turning "a dependency entered unlocked" into a hard red where a
# red is cheap and attributable.
_malf_lockfile_args() {
    [[ -f "$MALF_DIR/conan.lock" ]] || return 0
    echo "--lockfile=$MALF_DIR/conan.lock"
    [[ -n "${MALF_LOCKFILE_STRICT:-}" ]] || echo "--lockfile-partial"
}

_malf_conan_install_args() {
    local build_type="${MALF_CONFIG:-Release}"
    # shellcheck disable=SC2046
    echo "--build=missing" \
         "--profile:host=$MALF_PROFILE" \
         "--profile:build=$MALF_BUILD_PROFILE" \
         "-s" "build_type=$build_type" \
         $(_malf_lockfile_args)
}

_malf_editable_add() {
    local pkg_dir="$1"
    local pkg_ref name version
    pkg_ref="$(_malf_pkg_ref "$pkg_dir/conanfile.py")"
    # Extract name and version from ref (name/version)
    name="${pkg_ref%/*}"
    version="${pkg_ref#*/}"
    # Evict any STALE-version editable for this package before (re-)registering the
    # current one. The registry (editable_packages.json) is keyed by name/version, and
    # `conan editable add` REFUSES a version that mismatches the recipe (so a bump can't
    # add the new ref atop the old) — but conan never revalidates EXISTING entries, so a
    # coordinated bump (e.g. 1.5.3 -> 1.6.2) leaves the old ref orphaned at the same
    # path. The registry then carries BOTH refs, and a consumer still resolving the old
    # pin mid-bump silently builds from the stale editable. Removing every other-version
    # ref for this name first makes the per-build refresh self-healing across bumps — the
    # normal "bump then build the consumer" cycle needs no manual `editables sync`.
    # Idempotent: re-adding the current ref over itself is a no-op; the loop skips it.
    local existing
    while IFS= read -r existing; do
        [[ -n "$existing" && "$existing" != "$pkg_ref" ]] || continue
        conan editable remove --refs "$existing" >/dev/null 2>&1 || true
    done < <(conan editable list 2>/dev/null | grep -E "^${name}/")
    # Register this package as an editable pointing to its source directory
    conan editable add "$pkg_dir" --name="$name" --version="$version" -of "$pkg_dir"
}

_malf_editables_clear() {
    # Remove all editables by deleting the Conan editables config file
    # (Conan doesn't support removing all editables via command line)
    rm -f "$CONAN_HOME/editable_packages.json"
}

_malf_editable_build_dir() {
    # Build-type-keyed (2026-06-04 editable-isolation pass): editables build into <pkg>/build[-<key>],
    # MATCHING the recipe layout `cpp.build.libdirs = [os.environ.get("MALF_EDITABLE_BUILD_DIR","build")]`
    # (exported by _malf_apply_profile). So a keyed-profile consumer (gcc-15 / clang-21-libc++ / asan)
    # links the dep's OWN keyed build — no cross-stdlib/-compiler ABI mismatch. (The clang-21/libc++ leg
    # surfaced the old bug: a libc++ TU linking a libstdc++ editable .a — `__1` vs `__cxx11` mangling.)
    # ALWAYS profile-named now (default -> <pkg>/build-clang21-libcxx-release); a raw
    # `conan create --profile X` (env unset) reads the same name from the profile's
    # user.malf:editable_build_dir conf; the recipes' bare-"build" fallback is the
    # no-profile-conf last resort only. [[malf-build-type-isolation]] — this is the
    # "reviewed conanfile-layout pass".
    local pkg_dir="$1"
    echo "$pkg_dir/${MALF_EDITABLE_BUILD_DIR:-build}"
}

_malf_cmake_feature_args() {
    local target="$1"
    local tests="$2"
    local benches="$3"
    local cmakelists="$target/CMakeLists.txt"
    [[ -f "$cmakelists" ]] || return 0
    python3 - "$cmakelists" "$tests" "$benches" <<'PY'
import pathlib
import re
import sys

text = pathlib.Path(sys.argv[1]).read_text()
tests = sys.argv[2]
benches = sys.argv[3]
for name in re.findall(r"option\s*\(\s*([A-Za-z_][A-Za-z0-9_]*)", text):
    if "BUILD_TESTS" in name:
        print(f"-D{name}={tests}")
    elif "BUILD_BENCH" in name:
        print(f"-D{name}={benches}")
PY
}

_malf_dependency_cmake_args() {
    _malf_cmake_feature_args "$1" OFF OFF
}

_malf_build_editable_package() {
    local pkg_dir="$1"
    local build_dir pkg_ref user_presets_backup
    pkg_ref="$(_malf_pkg_ref "$pkg_dir/conanfile.py")"
    # Content-only packages (a conanfile but no CMakeLists.txt — e.g. a scenario/data corpus that
    # ships files via cpp_info.resdirs) are NOT CMake projects. Consumers read them straight from the
    # editable layout, so there is nothing to configure or build. Skip the CMake build for them.
    if [[ ! -f "$pkg_dir/CMakeLists.txt" ]]; then
        echo "malf: editable $pkg_ref is content-only (no CMakeLists.txt) — nothing to build"
        return 0
    fi
    build_dir="$(_malf_editable_build_dir "$pkg_dir")"
    mkdir -p "$build_dir"

    echo "malf: building editable $pkg_ref in $build_dir"

    user_presets_backup="$(_malf_backup_user_presets "$pkg_dir")"

    # shellcheck disable=SC2046
    if ! conan install "$pkg_dir" \
        --output-folder="$build_dir" \
        $(_malf_conan_install_args); then
        _malf_restore_user_presets "$pkg_dir" "$user_presets_backup"
        return 1
    fi

    _malf_write_user_presets "$pkg_dir" "$build_dir"

    local cmake_args=()
    mapfile -t cmake_args < <(_malf_dependency_cmake_args "$pkg_dir")
    if ! _malf_configure_and_build "$pkg_dir" "$build_dir" "${cmake_args[@]}"; then
        _malf_restore_user_presets "$pkg_dir" "$user_presets_backup"
        return 1
    fi

    _malf_restore_user_presets "$pkg_dir" "$user_presets_backup"
}

_malf_bootstrap_workspace_deps() {
    local target="$1"
    # 1 (default) includes the target's test_requires editables in the rebuild
    # set; cmd_build passes 0 since a non-test build never links them.
    local include_test_requires="${2:-1}"

    if [[ "$MALF_AUTO_WORKSPACE_DEPS" == "0" ]]; then
        return 0
    fi

    local entries=()
    mapfile -t entries < <(_malf_workspace_dep_entries "$target" "$include_test_requires")
    if [[ ${#entries[@]} -eq 0 ]]; then
        return 0
    fi

    local entry ref dep_dir

    echo "malf: registering local workspace dependencies as editables from $MALF_WORKSPACE_ROOT"
    for entry in "${entries[@]}"; do
        IFS=$'\t' read -r ref dep_dir <<< "$entry"
        [[ -n "$ref" && -n "$dep_dir" ]] || continue
        _malf_editable_add "$dep_dir"
    done

    for entry in "${entries[@]}"; do
        IFS=$'\t' read -r ref dep_dir <<< "$entry"
        [[ -n "$ref" && -n "$dep_dir" ]] || continue
        _malf_build_editable_package "$dep_dir"
    done
}

_malf_write_user_presets() {
    local target="$1"
    local build_dir="$2"
    local rel_build
    rel_build="$(realpath --relative-to="$target" "$build_dir" 2>/dev/null || echo "build")"
    cat > "$target/CMakeUserPresets.json" <<JSON
{
    "version": 4,
    "vendor": {
        "conan": {}
    },
    "include": [
        "$rel_build/CMakePresets.json"
    ]
}
JSON
}

_malf_backup_user_presets() {
    local target="$1"
    local user_presets="$target/CMakeUserPresets.json"
    if [[ -f "$user_presets" ]]; then
        local backup
        backup="$(mktemp -t CMakeUserPresets.XXXXXX.json)"
        cp "$user_presets" "$backup"
        echo "$backup"
        return
    fi
    echo ""
}

_malf_restore_user_presets() {
    local target="$1"
    local backup="${2:-}"
    local user_presets="$target/CMakeUserPresets.json"
    if [[ -n "$backup" && -f "$backup" ]]; then
        cp "$backup" "$user_presets"
        rm -f "$backup"
    else
        rm -f "$user_presets"
    fi
}

# Build parallelism. Sanitizer builds (ASan/UBSan/MSan) are FAR heavier in the clang frontend:
# import-std module instantiation under instrumentation drives deep frontend recursion AND ~3 GB/TU.
# Under full -j$(nproc) on a memory-tight box this OOM-thrashes AND starves the frontend's stack →
# the intermittent "stack exhaustion" frontend ICE on the heaviest module TU (insight-eidos's
# metalog_pyramid.cpp, which imports the big metalog compose/diff module forest). So for a sanitizer
# build ONLY, cap parallelism by available memory (the determinism-gate precedent, ~3 GB/job).
# Non-sanitizer builds keep full -j (byte-identical behaviour to before).
_malf_build_jobs() {
    local ncpu; ncpu="$(nproc 2>/dev/null || echo 2)"
    [[ "${MALF_IS_SANITIZER:-0}" == "1" ]] || { echo "$ncpu"; return; }
    local mem_gb; mem_gb="$(awk '/MemAvailable/{print int($2/1024/1024)}' /proc/meminfo 2>/dev/null || echo 4)"
    local jobs=$(( mem_gb / 3 )); (( jobs < 1 )) && jobs=1; (( jobs > ncpu )) && jobs=$ncpu
    echo "$jobs"
}

_malf_configure_and_build() {
    local target="$1"
    local build_dir="$2"
    shift 2
    local preset
    preset="$(_malf_preset)"
    cmake --preset "$preset" -S "$target" -B "$build_dir" \
        -DCMAKE_EXPORT_COMPILE_COMMANDS=ON \
        "$@"
    local jobs; jobs="$(_malf_build_jobs)"
    if [[ "${MALF_IS_SANITIZER:-0}" == "1" ]]; then
        # The companion to the -j cap: give the clang frontend stack headroom for the deep
        # import-std module instantiation under instrumentation (the named "stack exhaustion"
        # mechanism). The soft rlimit is inherited by ninja's child compiler processes; raising
        # it is best-effort (a lower hard cap is fine — the -j cap still relieves the pressure).
        ulimit -s 131072 2>/dev/null || true   # 128 MB frontend stack (default ~8 MB)
        echo "malf: sanitizer build — -j$jobs (mem-aware) + 128MB compiler stack (frontend-ICE guard)" >&2
    fi
    cmake --build "$build_dir" -j"$jobs"
}

_malf_repo_root() {
    # The repo root a package belongs to (where .clangd + the merged compile DB
    # live): the package's git toplevel — invocation-CWD-independent, so a
    # subfolder build feeds the same editor DB a repo-root build does. Falls
    # back to the package dir itself outside any git checkout.
    git -C "$1" rev-parse --show-toplevel 2>/dev/null || echo "$1"
}

_malf_merge_compile_commands() {
    # Fold the just-built package's compile_commands.json into the root DB that
    # .clangd reads (CompilationDatabase: build-clang21-libcxx-release — the DEFAULT
    # leg's named build root of the package's REPO; .clangd is static, so it tracks
    # the dev default). This keeps the editor's index in step with the incremental
    # build WITHOUT the full `malf commands` workspace walk: one file merge, no
    # reconfigure. Entries are keyed by source file — the freshly built package's
    # entries replace any stale entry for the same file, while entries contributed
    # by *other* packages already in the root DB are preserved (multi-package repos).
    local build_dir="$1" target="$2"
    local root_db="$(_malf_default_build_root "$(_malf_repo_root "$target")")/compile_commands.json"
    local pkg_db="$build_dir/compile_commands.json"
    # Building the repo root itself: cmake already wrote the root DB in place.
    [[ "$(realpath -m "$pkg_db")" == "$(realpath -m "$root_db")" ]] && return 0
    [[ -f "$pkg_db" ]] || return 0
    python3 - "$pkg_db" "$root_db" <<'PY'
import json, sys
from pathlib import Path

pkg_db = Path(sys.argv[1])
root_db = Path(sys.argv[2])

try:
    pkg_entries = json.loads(pkg_db.read_text())
except Exception as exc:  # malformed/partial DB: leave the root untouched
    raise SystemExit(f"malf: skipping compile_commands merge ({pkg_db}: {exc})")

root_entries = []
if root_db.exists():
    try:
        root_entries = json.loads(root_db.read_text())
    except Exception:
        root_entries = []  # stale/corrupt root DB is rebuilt from this package

# Files just rebuilt take precedence: drop their prior root entries, then append.
rebuilt = {e.get("file") for e in pkg_entries}
merged = [e for e in root_entries if e.get("file") not in rebuilt]
merged.extend(pkg_entries)

root_db.parent.mkdir(parents=True, exist_ok=True)
root_db.write_text(json.dumps(merged, indent=2) + "\n")
print(f"malf: refreshed {root_db} for clangd "
      f"({len(merged)} entries, {len(pkg_entries)} from this build)")
PY
}

# ─── Commands ────────────────────────────────────────────────────────────────

# The ONE compile flow all three verbs share: conan install + configure + build
# with the FULL target surface ON — package + tests + benches ("malf build
# compiles everything"). The verbs differ only in what they RUN afterwards
# (test -> ctest, bench -> the bench executables), never in what they compile —
# so a TU that only a test or bench pulls in can no longer slip past the desk
# and first fail in the release pipeline (the 1.7.2 drift-at-tag class).
# Content-only packages (a conanfile but no CMakeLists.txt — umbrella
# metapackages, scenario/data corpora) have nothing to compile: return 0 with
# a note, and the caller skips its run phase too.
_malf_build_flow() {
    local target="$1"
    if [[ ! -f "$target/CMakeLists.txt" ]]; then
        echo "malf: $(_malf_pkg_ref "$target/conanfile.py") is content-only (no CMakeLists.txt) — nothing to compile"
        return 0
    fi
    local build_dir
    build_dir="$(_malf_build_dir "$target")"
    mkdir -p "$build_dir"

    _malf_bootstrap_workspace_deps "$target"

    local user_presets_backup rc=0
    user_presets_backup="$(_malf_backup_user_presets "$target")"
    # Conan writes CMakeUserPresets.json to the source dir with multiple includes,
    # causing "Duplicate preset" errors. Rewrite it to include only the local build dir.
    # shellcheck disable=SC2046
    if conan install "$target" \
        --output-folder="$build_dir" \
        $(_malf_conan_install_args); then
        _malf_write_user_presets "$target" "$build_dir"
        local cmake_args=()
        mapfile -t cmake_args < <(_malf_cmake_feature_args "$target" ON ON)
        _malf_configure_and_build "$target" "$build_dir" "${cmake_args[@]}" || rc=1
    else
        rc=1
    fi
    if [[ $rc -ne 0 ]]; then
        _malf_restore_user_presets "$target" "$user_presets_backup"
        return 1
    fi
    [[ -n "$user_presets_backup" ]] && rm -f "$user_presets_backup"
    _malf_merge_compile_commands "$build_dir" "$target"
}

cmd_build() {
    local subdir="" fwd=()
    MALF_CONFIG="Debug"
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --debug)   MALF_CONFIG="Debug"; fwd+=("$1") ;;
            --release) MALF_CONFIG="Release"; fwd+=("$1") ;;
            # Select any registry profile (malf/profiles/<name>): build type + clean
            # build-context for sanitizers are derived from the profile.
            --profile) fwd+=("$1" "$2"); shift; _malf_apply_profile "$1" ;;
            # Sugar: ASan/UBSan(+libFuzzer-via-target) gate profile (canon→eidos parse path).
            --asan)    _malf_apply_profile "$MALF_ASAN_PROFILE"; fwd+=("$1") ;;
            *) subdir="$1" ;;
        esac
        shift
    done

    _malf_resolve_target_or_sweep build "$subdir" "${fwd[@]}"
    local target="$MALF_TARGET"

    _malf_use_keyed_cache

    echo "=== malf build: $target ($MALF_CONFIG${MALF_PROFILE_NAME:+, $MALF_PROFILE_NAME}) ==="
    _malf_build_flow "$target"
    echo "=== done: $(_malf_build_dir "$target") ==="
}

cmd_test() {
    local subdir="" fwd=()
    local gtest_filter=""
    local verbose=false
    MALF_CONFIG="Debug"
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --debug)   MALF_CONFIG="Debug"; fwd+=("$1") ;;
            --release) MALF_CONFIG="Release"; fwd+=("$1") ;;
            --profile) fwd+=("$1" "$2"); shift; _malf_apply_profile "$1" ;;
            --asan)    _malf_apply_profile "$MALF_ASAN_PROFILE"; fwd+=("$1") ;;
            --verbose) verbose=true; fwd+=("$1") ;;
            --filter)
                shift
                [[ $# -gt 0 ]] || { echo "malf test: --filter requires a pattern" >&2; exit 1; }
                gtest_filter="$1"; fwd+=(--filter "$1")
                ;;
            *) subdir="$1" ;;
        esac
        shift
    done

    _malf_resolve_target_or_sweep test "$subdir" "${fwd[@]}"
    local target="$MALF_TARGET"

    _malf_use_keyed_cache

    # End-to-end packages whose tests rely on optimized producer code paths
    # cannot meaningfully run under -O0/Debug (throughput drops 10–30x and
    # the in-test drain watchdog times out before the scenario completes).
    # Force such packages to Release so `malf test` produces meaningful
    # results regardless of MALF_CONFIG.
    case "$(basename "$target")" in
        insight-e2e)
            if [[ "$MALF_CONFIG" != "Release" ]]; then
                echo "malf test: insight-e2e requires Release (e2e throughput-sensitive); overriding MALF_CONFIG=$MALF_CONFIG -> Release" >&2
                MALF_CONFIG="Release"
            fi
            ;;
    esac

    echo "=== malf test: $target ($MALF_CONFIG) ==="

    _malf_build_flow "$target"

    if [[ ! -f "$target/CMakeLists.txt" ]]; then
        return 0   # content-only: nothing to run either
    fi
    local ctest_args=(--test-dir "$(_malf_build_dir "$target")" --output-on-failure)
    $verbose && ctest_args+=(--verbose)
    [[ -n "$gtest_filter" ]] && ctest_args+=(-R "$gtest_filter")
    ctest "${ctest_args[@]}"
}

cmd_lint() {
    local console=false all_files=false
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -c|--console)   console=true ;;
            --all-files)    all_files=true ;;
            *) echo "malf lint: unknown option $1" >&2; exit 1 ;;
        esac
        shift
    done

    # clang-tidy config: prefer CWD, fall back to the canonical config in this repo (config/)
    local tidy_config=""
    if [[ -f "$CWD/.clang-tidy" ]]; then
        tidy_config="$CWD/.clang-tidy"
    elif [[ -f "$MALF_DIR/config/.clang-tidy" ]]; then
        tidy_config="$MALF_DIR/config/.clang-tidy"
    fi

    # compile_commands.json: prefer CWD/compile_commands.json, then the default
    # leg's named build root (where _malf_merge_compile_commands maintains the DB).
    local comp_db=""
    if [[ -f "$CWD/compile_commands.json" ]]; then
        comp_db="$CWD"
    elif [[ -f "$(_malf_default_build_root "$CWD")/compile_commands.json" ]]; then
        comp_db="$(_malf_default_build_root "$CWD")"
    fi

    if [[ -z "$comp_db" ]]; then
        echo "malf lint: warning: no compile_commands.json found; clang-tidy may miss context" >&2
    fi

    local output_file=""
    if ! $console; then
        output_file="$CWD/lint_output.txt"
        > "$output_file"
    fi

    # Use the clang-tidy from the SAME install as the build compiler (clang-21).
    # A C++ module BMI (.pcm) is pinned to the exact clang BUILD that produced it, so a
    # clang-tidy from a different install — e.g. a 21.1.0 release in /usr/local vs the
    # apt.llvm.org 21.1.8 snapshot in /usr/lib/llvm-21 — can't read it, and every TU
    # that imports a module errors out. Deriving clang-tidy from clang-21's resolved
    # path keeps them in lockstep (and the resource-dir below consistent). Fall back to
    # PATH if that install ships no clang-tidy, and say so.
    local clang_bin clang_tidy_bin="" install_tidy="" tidy_matches_build=false
    clang_bin="$(command -v clang-21 || command -v clang || true)"
    if [[ -n "$clang_bin" ]]; then
        install_tidy="$(dirname "$(readlink -f "$clang_bin")")/clang-tidy"
        # Same install as the build clang → its clang-tidy can read this build's
        # module BMIs (.pcm), so C++ module files become lintable (see the filter below).
        [[ -x "$install_tidy" ]] && { clang_tidy_bin="$install_tidy"; tidy_matches_build=true; }
    fi
    if [[ -z "$clang_tidy_bin" ]]; then
        clang_tidy_bin="$(command -v clang-tidy-21 || command -v clang-tidy || true)"
        [[ -n "$install_tidy" && -n "$clang_tidy_bin" ]] && \
            echo "malf lint: note: $install_tidy missing; using $clang_tidy_bin (a different clang build — module BMIs won't match it). 'sudo apt install clang-tidy-21' from the same source as clang-21 to align." >&2
    fi
    [[ -n "$clang_tidy_bin" ]] || { echo "malf lint: error: clang-tidy not found" >&2; exit 1; }

    # clang-tidy needs clang-21's OWN resource-dir to find its builtin headers
    # (stddef.h / limits.h via include_next), else a libc++ DB fails to resolve them.
    # -w mutes compiler warnings so only clang-tidy diagnostics surface.
    local extra_args=("-extra-arg=-w")
    if [[ -n "$clang_bin" ]]; then
        local res_dir
        res_dir="$($clang_bin -print-resource-dir 2>/dev/null || true)"
        [[ -n "$res_dir" && -d "$res_dir" ]] && extra_args+=("-extra-arg=-resource-dir=${res_dir}")
    fi

    [[ -n "$comp_db" ]] && extra_args+=("-p" "$comp_db")
    [[ -n "$tidy_config" ]] && extra_args+=("--config-file=$tidy_config")
    # Restrict diagnostic output to files under the project root only.
    # Without this clang-tidy follows #includes into Conan/system headers
    # and reports tens of thousands of spurious warnings.
    # Exclude .conan2/, build/ + the keyed build-*/ dirs, and test_package/ to avoid
    # linting dependencies and CMake-generated probe TUs (e.g. CMakeCXXCompilerId.cpp).
    # The `build` token here prefix-matches build-gcc15-release/ etc. too.
    # tests/ + benchmarks/: their TUs `import <pkg>.test;`/`import <pkg>.bench;` (the
    # full-surface re-export aggregators); under the -P parallel fan-out below, concurrent
    # clang-tidy processes deserialising those heavy BMIs race in clang::ASTReader and
    # SIGSEGV (the upstream module ASTReader bug — finishPendingActions ← addedMember). All
    # 64 library TUs lint clean (verified 2026-06-11); only the test/bench aggregator-imports
    # crash, and only in parallel. Excluded here so the gate covers 100% of SHIPPING source;
    # test/bench keep -Werror + sanitizers. Remove when clang's module ASTReader is fixed.
    extra_args+=("--header-filter=^${CWD}/(?!\.conan2|build|test_package|technical_docs|.*/tests/|.*/benchmarks/).*")

    # Collect files: git-changed (default) or all
    local files=()
    if $all_files; then
        # Shared hazard baseline + lint's policy exclusions, PRUNED (a -not -path
        # test still descends into every entry beneath the dir it excludes), and
        # size-capped so a stray blob can't hand clang-tidy a multi-GB TU.
        local -a lint_prune=()
        mapfile -d '' -t lint_prune < <(_malf_prune_args $MALF_LINT_EXCLUDE_EXTRA)
        local oversized_lint
        oversized_lint="$(find "$CWD" \
            \( -type d \( "${lint_prune[@]}" \) -prune \) -o \
            \( -type f \( -name "*.cpp" -o -name "*.cc" -o -name "*.cxx" -o -name "*.hpp" -o -name "*.h" -o -name "*.cppm" \) \
               ! -size "-${MALF_SOURCE_MAX_FILE_KB}k" -printf '  %p (%s bytes)\n' \))"
        if [[ -n "$oversized_lint" ]]; then
            echo "malf lint: SKIPPED ${MALF_SOURCE_MAX_FILE_KB}KB+ file(s) — not linted:" >&2
            echo "$oversized_lint" >&2
        fi
        while IFS= read -r f; do files+=("$f"); done < <(
            find "$CWD" \
                \( -type d \( "${lint_prune[@]}" \) -prune \) -o \
                \( -type f \( -name "*.cpp" -o -name "*.cc" -o -name "*.cxx" -o -name "*.hpp" -o -name "*.h" -o -name "*.cppm" \) \
                   -size "-${MALF_SOURCE_MAX_FILE_KB}k" -print \)
        )
    else
        while IFS= read -r f; do
            [[ "$f" =~ \.(cpp|cc|cxx|h|hpp|cppm)$ ]] && [[ -f "$CWD/$f" ]] && [[ "$f" != */test_package/* ]] && [[ "$f" != */technical_docs/* ]] && [[ "$f" != */tests/* ]] && [[ "$f" != */benchmarks/* ]] && files+=("$CWD/$f")
        done < <(git -C "$CWD" diff --name-only HEAD 2>/dev/null || true)
        while IFS= read -r f; do
            [[ "$f" =~ \.(cpp|cc|cxx|h|hpp|cppm)$ ]] && [[ -f "$CWD/$f" ]] && [[ "$f" != */test_package/* ]] && [[ "$f" != */technical_docs/* ]] && [[ "$f" != */tests/* ]] && [[ "$f" != */benchmarks/* ]] && files+=("$CWD/$f")
        done < <(git -C "$CWD" diff --name-only --cached 2>/dev/null || true)
        # dedupe
        mapfile -t files < <(printf '%s\n' "${files[@]}" | sort -u)
    fi

    # C++ module files are lintable ONLY when clang-tidy is the same build as the
    # project's compiler: a module BMI (.pcm) is pinned to the exact clang build, so a
    # mismatched clang-tidy errors out ("module file '…' built from a different
    # branch") on every module INTERFACE unit (.cppm) and every TU that `import`s a
    # named module (the module-import tests, plus 1.5.1 production imports like
    # coderoast-server's `import coderoast.*`). When clang-tidy MATCHES the build
    # (derived from clang-21's own install above) we lint them; otherwise we skip them
    # (they still compile in the build + run as module-import tests) and rely on the
    # note printed above to align the toolchain.
    if ! $tidy_matches_build; then
        local lintable=()
        local _f
        for _f in "${files[@]}"; do
            [[ "$_f" == *.cppm ]] && continue
            grep -qE '^[[:space:]]*(export[[:space:]]+)?import[[:space:]]+[A-Za-z_]' "$_f" 2>/dev/null && continue
            lintable+=("$_f")
        done
        files=("${lintable[@]}")
    fi

    if [[ ${#files[@]} -eq 0 ]]; then
        echo "malf lint: no files to check"
        return 0
    fi

    echo "malf lint: checking ${#files[@]} file(s) ..."

    # Parallel execution via xargs -P. Cap at 4 jobs (a real TU peaks at ~436 MB,
    # measured) AND cap each child's address space below — the job count alone
    # bounds how MANY processes run, not how large any one of them grows, which
    # is the half that lets a single pathological TU take the box down.
    local jobs
    jobs="$(( $(nproc) < 4 ? $(nproc) : 4 ))"
    export _MALF_MEM_LIMIT="$MALF_SOURCE_MEM_LIMIT_KB"

    local tmpdir lint_status=0
    tmpdir="$(mktemp -d -t malf_lint.XXXXXX)"

    local counter_file="$tmpdir/_progress"
    touch "$counter_file"
    export _MALF_TIDY="$clang_tidy_bin"
    export _MALF_ARGS="${extra_args[*]}"
    export _MALF_TMP="$tmpdir"
    export _MALF_CWD="$CWD"
    export _MALF_TOTAL="${#files[@]}"
    export _MALF_COUNTER="$counter_file"

    # Pass each file as $1 to avoid xargs {} substitution inside the script body.
    # shellcheck disable=SC2016
    printf '%s\0' "${files[@]}" \
        | xargs -0 -P "$jobs" -n 1 bash -c '
            f="$1"
            ulimit -v "$_MALF_MEM_LIMIT"
            out=$($_MALF_TIDY $_MALF_ARGS -quiet "$f" 2>&1); rc=$?
            filtered=$(printf "%s\n" "$out" \
                | grep -vE "^\[|^Suppressed|warnings generated|^$" || true)
            key=$(printf "%s" "$f" | md5sum | cut -c1-8)
            [ -n "$filtered" ] && printf "%s\n" "$filtered" > "$_MALF_TMP/${key}.out"
            printf "x" >> "$_MALF_COUNTER"
            n=$(wc -c < "$_MALF_COUNTER")
            printf "[%d/%d] %s\n" "$n" "$_MALF_TOTAL" "${f#"$_MALF_CWD/"}" >&2
            exit $rc
        ' _ || lint_status=1

    # Merge in original file order, then deduplicate identical lines.
    # Headers included by multiple TUs produce identical diagnostics; awk
    # keeps the first occurrence of each line and drops repeats.
    local merged="$tmpdir/_merged.out"
    for file in "${files[@]}"; do
        local key
        key="$(printf '%s' "$file" | md5sum | cut -c1-8)"
        local slot="$tmpdir/${key}.out"
        [[ -f "$slot" ]] && cat "$slot" >> "$merged"
    done

    if [[ -f "$merged" ]]; then
        local deduped
        deduped="$(awk '!seen[$0]++' "$merged")"
        if [[ -n "$output_file" ]]; then
            printf '%s\n' "$deduped" >> "$output_file"
        else
            printf '%s\n' "$deduped"
        fi
    fi

    rm -rf "$tmpdir"
    unset _MALF_TIDY _MALF_ARGS _MALF_TMP _MALF_CWD _MALF_TOTAL _MALF_COUNTER _MALF_MEM_LIMIT

    if [[ -n "$output_file" ]]; then
        echo "malf lint: output written to $output_file"
    fi
    return "$lint_status"
}

# Emit `find` prune arguments for the shared hazard baseline plus any per-command
# additions passed as "$@". Consumed as: find DIR \( -type d \( ARGS \) -prune \) -o ...
_malf_prune_args() {
    local -a out=()
    local dir_pattern
    for dir_pattern in $MALF_SOURCE_EXCLUDE_DIRS "$@"; do
        out+=(-name "$dir_pattern" -o)
    done
    unset "out[$((${#out[@]} - 1))]"   # drop the trailing -o
    printf '%s\0' "${out[@]}"
}

cmd_format() {
    local check=false
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --check) check=true ;;
            *) echo "malf format: unknown option $1" >&2; exit 1 ;;
        esac
        shift
    done

    # Use the clang-format from the SAME install as the build compiler (clang-21) for
    # consistency. clang-format is a pure formatter — a version skew can't error like
    # clang-tidy's BMI mismatch — but different clang-format versions reflow code
    # differently (churn), so match the toolchain. Derive from clang-21; fall back to PATH.
    local clang_bin clang_format_bin="" install_fmt=""
    clang_bin="$(command -v clang-21 || command -v clang || true)"
    if [[ -n "$clang_bin" ]]; then
        install_fmt="$(dirname "$(readlink -f "$clang_bin")")/clang-format"
        [[ -x "$install_fmt" ]] && clang_format_bin="$install_fmt"
    fi
    if [[ -z "$clang_format_bin" ]]; then
        clang_format_bin="$(command -v clang-format-21 || command -v clang-format || true)"
        [[ -n "$install_fmt" && -n "$clang_format_bin" ]] && \
            echo "malf format: note: $install_fmt missing; using $clang_format_bin (clang-21 is the build compiler). 'sudo apt install clang-format-21' for version-matched formatting." >&2
    fi
    [[ -n "$clang_format_bin" ]] || { echo "malf format: error: clang-format not found" >&2; exit 1; }

    # clang-format config: prefer CWD, fall back to malf dir
    local format_args
    if $check; then
        format_args=(--dry-run --Werror -style=file)
        echo "=== malf format: checking ==="
    else
        format_args=(-i -style=file)
        echo "=== malf format: formatting ==="
    fi

    # If no .clang-format in CWD, copy from malf dir so -style=file works
    if [[ ! -f "$CWD/.clang-format" && -f "$MALF_DIR/.clang-format" ]]; then
        cp "$MALF_DIR/.clang-format" "$CWD/.clang-format"
        echo "malf format: copied .clang-format from malf dir"
    fi

    # Prune list → find args. `-name` glob-matches, so `build-*` works as written.
    local -a prune_args=()
    mapfile -d '' -t prune_args < <(_malf_prune_args $MALF_FORMAT_EXCLUDE_EXTRA)

    local -a source_globs=(
        -name "*.cpp" -o -name "*.cxx" -o -name "*.cc"
        -o -name "*.h" -o -name "*.hpp" -o -name "*.cppm"
    )

    # A skipped file must be REPORTED, never silently dropped — a silent cap
    # reads as "formatted everything" when it did not. `! -size -Nk` is the
    # exact complement of the `-size -Nk` filter below, so nothing falls in a gap.
    local oversized
    oversized="$(find "$CWD" \
        \( -type d \( "${prune_args[@]}" \) -prune \) -o \
        \( -type f \( "${source_globs[@]}" \) ! -size "-${MALF_SOURCE_MAX_FILE_KB}k" \
           -printf '  %p (%s bytes)\n' \))"
    if [[ -n "$oversized" ]]; then
        echo "malf format: SKIPPED ${MALF_SOURCE_MAX_FILE_KB}KB+ file(s) — clang-format needs ~500x a file's size in RAM:" >&2
        echo "$oversized" >&2
        echo "malf format: these are not formatted. Exclude their directory (MALF_FORMAT_EXCLUDE_EXTRA) if they are not source." >&2
    fi

    # `ulimit -v` applies to the clang-format child, so an overrun aborts the
    # formatter instead of the machine. Batched (-n) so one pathological file
    # cannot cost the whole run, and so the surviving output names the culprit.
    find "$CWD" \
        \( -type d \( "${prune_args[@]}" \) -prune \) -o \
        \( -type f \( "${source_globs[@]}" \) -size "-${MALF_SOURCE_MAX_FILE_KB}k" -print0 \) \
    | xargs -0 -r -n "$MALF_FORMAT_BATCH_SIZE" \
        bash -c 'ulimit -v "$0"; exec "$@"' \
        "$MALF_SOURCE_MEM_LIMIT_KB" "$clang_format_bin" "${format_args[@]}"
}

_malf_resolve_preset() {
    # Resolve the conan configure-preset name (conan-debug / conan-release) the way
    # cmake does: CMakePresets.json then CMakeUserPresets.json in the SOURCE dir,
    # following "include" chains. Prints the name, or nothing if none is found.
    python3 -c "
import json, pathlib, sys
subdir = pathlib.Path(sys.argv[1])
for fname in ('CMakePresets.json', 'CMakeUserPresets.json'):
    src = subdir / fname
    if not src.exists():
        continue
    try:
        data = json.loads(src.read_text())
    except Exception:
        continue
    for cp in data.get('configurePresets', []):
        if cp.get('name', '') in ('conan-release', 'conan-debug'):
            print(cp['name']); sys.exit(0)
    for inc in data.get('include', []):
        inc_path = (subdir / inc).resolve()
        if not inc_path.exists():
            continue
        try:
            inc_data = json.loads(inc_path.read_text())
        except Exception:
            continue
        for cp in inc_data.get('configurePresets', []):
            if cp.get('name', '') in ('conan-release', 'conan-debug'):
                print(cp['name']); sys.exit(0)
" "$1" 2>/dev/null || true
}

_malf_configure_test_package() {
    # Configure a package's test_package so clangd indexes it too. conan create
    # builds it in a temp dir that the editor never sees, so we re-install its deps
    # and configure it in-tree. The COMPILER comes from the profile buildenv
    # (CC/CXX) — sourced below — not the toolchain (which only adds stdlib flags like
    # -stdlib=libc++); without it a libc++ profile would fall back to system g++.
    local subdir="$1" tp_build="$2"
    local main_ref
    main_ref="$(_malf_pkg_ref "$subdir/conanfile.py")"
    # Fresh every run: the test_package build dir is unkeyed (reused across
    # profiles), so a stale CMakeCache/toolchain from a prior profile clashes (a
    # cached g++ vs a libc++ toolchain). Cheap — deps stay conan-cached.
    rm -rf "$tp_build"
    mkdir -p "$tp_build"
    # Deps: the tested package ($main_ref == self.tested_reference_str) + every
    # literal-versioned (test_)requires() in the test_package conanfile (e.g. a
    # private visible=False dep it re-requires for itself).
    local tp_req_args=("--requires=$main_ref")
    while IFS= read -r req; do
        [[ -n "$req" ]] && tp_req_args+=("--requires=$req")
    done < <(python3 -c "
import re, pathlib
txt = pathlib.Path('$subdir/test_package/conanfile.py').read_text()
for r in re.findall(r\"(?:test_)?requires\\s*\\(\\s*['\\\"]([^'\\\"]+)['\\\"]\\s*\\)\", txt):
    print(r)
" 2>/dev/null || true)
    echo "malf commands: installing test_package deps ($main_ref) in $(basename "$subdir")"
    conan install \
        "${tp_req_args[@]}" \
        -g CMakeToolchain -g CMakeDeps \
        --output-folder="$tp_build" \
        --profile:host="$MALF_PROFILE" \
        --profile:build="$MALF_PROFILE" \
        --build=missing \
        -c "tools.cmake.cmaketoolchain:generator=Ninja" \
        -s "build_type=Debug" \
        2>&1 | grep -vE "^$|^======|^Requirements|^Packages|^Build" || true

    local tp_toolchain="$tp_build/conan_toolchain.cmake"
    [[ -f "$tp_toolchain" ]] || return 0
    # The tested module package ships its native config (FILE_SET CXX_MODULES) into the dir
    # malf JUST configured it in — the PARENT of tp_build (= _malf_build_dir "$subdir", the
    # package-anchored tree, which IS the editable build dir the recipe's builddir resolves
    # to). Point CMAKE_PREFIX_PATH at it so find_package(<pkg>) hits the fresh config.
    local main_build_dir; main_build_dir="$(dirname "$tp_build")"
    echo "malf commands: configuring $(basename "$subdir")/test_package"
    if ! ( source "$tp_build/conanbuild.sh" 2>/dev/null
           cmake -S "$subdir/test_package" \
                 -B "$tp_build" \
                 -G Ninja \
                 "-DCMAKE_TOOLCHAIN_FILE=$tp_toolchain" \
                 "-DCMAKE_PREFIX_PATH=$main_build_dir" \
                 -DCMAKE_BUILD_TYPE=Debug \
                 -DCMAKE_EXPORT_COMPILE_COMMANDS=ON ) \
             > "$tp_build/cmake_configure.log" 2>&1; then
        echo "malf commands: test_package configure FAILED:" >&2
        tail -20 "$tp_build/cmake_configure.log" >&2
    fi
}

_malf_merge_db_tree() {
    # Merge every compile_commands.json under the given build dirs into
    # <build_root>/compile_commands.json (what .clangd's CompilationDatabase
    # points at). Structure-agnostic.
    local build_root="$1"; shift
    local root_db="$build_root/compile_commands.json"
    python3 - "$root_db" "$@" << 'PY'
import json, sys
from pathlib import Path

root_output = Path(sys.argv[1]).resolve()
scan_dirs   = [Path(p) for p in sys.argv[2:]]

# A single-package repo configures into its own build dir, so its DB IS
# root_output — read it first so those entries survive (it was cleared before
# the walk for multi-package repos, so it is absent there).
dbs, seen_paths = [], set()
if root_output.exists():
    seen_paths.add(root_output)
    dbs.append(root_output)
for scan_dir in scan_dirs:
    for found in sorted(scan_dir.rglob("compile_commands.json")):
        found = found.resolve()
        if found not in seen_paths:
            seen_paths.add(found)
            dbs.append(found)

if not dbs:
    raise SystemExit(f"malf commands: no compile_commands.json under {', '.join(map(str, scan_dirs))} "
                     "(did every configure fail?)")

merged, seen = [], set()
for db in dbs:
    try:
        entries = json.loads(db.read_text())
    except Exception as exc:
        print(f"malf commands: warning: {db}: {exc}", file=sys.stderr)
        continue
    for e in entries:                       # one entry per file (clangd convention)
        key = e.get("file")
        if key not in seen:
            seen.add(key)
            merged.append(e)

root_output.write_text(json.dumps(merged, indent=2) + "\n")
print(f"malf commands: merged {len(dbs)} database(s) -> {root_output} "
      f"({len(merged)} entries)")
PY
}

cmd_compile_commands() {
    # Generate the repo-level compile_commands.json that .clangd reads
    # (CompilationDatabase: build-clang21-libcxx-release — the default leg's named
    # build root at the repo root). A repo is just a LIST of package dirs (the
    # member enumeration — a root recipe is a member too), so there is NO single-
    # vs-multi branch: each package is conan-installed, configured via its conan
    # preset (the SAME compiler/flags `malf build` uses), its test_package is
    # configured, and every emitted DB is merged. Debug config so test
    # targets match `malf build` / `malf test`.
    local build_root; build_root="$(_malf_build_dir "$CWD")"
    MALF_CONFIG="Debug"
    mkdir -p "$build_root"
    # Rebuild the editor DB from scratch: clear the merged output so a single-package
    # repo's own DB (whose build dir IS the merge root) is the only copy the
    # merge reads back in (no stale entries from a previous run).
    rm -f "$build_root/compile_commands.json"

    local members=() _ref _dir
    while IFS=$'\t' read -r _ref _dir; do
        [[ -n "$_ref" && -n "$_dir" ]] && members+=("$_dir")
    done < <(_malf_member_packages "$CWD")
    if [[ ${#members[@]} -eq 0 ]]; then
        echo "malf commands: no conanfile.py found under $CWD" >&2; exit 1
    fi

    local db_dirs=("$build_root")
    local pkg_dir
    for pkg_dir in "${members[@]}"; do
        local subdir subdir_name subdir_build
        subdir="$pkg_dir"
        subdir_name="$(basename "$subdir")"
        # Content-only packages (no CMakeLists.txt anywhere) have no TUs to index.
        if [[ ! -f "$subdir/CMakeLists.txt" && ! -f "$subdir/test_package/CMakeLists.txt" ]]; then
            echo "malf commands: $subdir_name is content-only — skipped"
            continue
        fi
        # Canonical build dir, mirroring `malf build` — package-anchored
        # (<pkg>/build-<key>), the ONE tree per (package, profile).
        subdir_build="$(_malf_build_dir "$subdir")"
        db_dirs+=("$subdir_build")

        # conan install if this build dir has no toolchain/preset yet, so deps
        # (including test_requires like gtest) are present before cmake configures.
        if [[ ! -f "$subdir_build/CMakePresets.json" ]]; then
            mkdir -p "$subdir_build"
            echo "malf commands: installing deps for $subdir_name"
            # shellcheck disable=SC2046
            conan install "$subdir" \
                --output-folder="$subdir_build" \
                $(_malf_conan_install_args) \
                2>&1 | grep -vE "^$|^======|^Requirements|^Packages|^Build" || true
        fi
        [[ -f "$subdir_build/CMakePresets.json" ]] || continue

        # Register/build the editable workspace deps this package needs.
        _malf_bootstrap_workspace_deps "$subdir"

        # test_package (if any) -> its own compile_commands.json.
        if [[ -f "$subdir/test_package/CMakeLists.txt" ]]; then
            _malf_configure_test_package "$subdir" "$subdir_build/test_package"
        fi

        # Point the source dir's CMakeUserPresets.json at the canonical build dir.
        # This MUST run AFTER the test_package install above. In a SINGLE-package repo
        # (subdir == repo root) that install — run from the repo root — APPENDS
        # build/test_package/CMakePresets.json to this very CMakeUserPresets.json
        # (conan updates an existing one unconditionally; the user_presets conf does not
        # suppress it). Both it and build/CMakePresets.json define `conan-debug`, so the
        # preset graph gains a duplicate and `cmake --preset conan-debug` aborts
        # ("Duplicate preset: conan-debug") — the package (with tests ON) then never
        # configures, and its unit-test TUs never reach the DB. Re-asserting the
        # canonical single-include here removes that pollution before we configure.
        _malf_write_user_presets "$subdir" "$subdir_build"

        # Configure the package itself via its preset -> compile_commands.json.
        # The preset's binaryDir is authoritative, so do NOT pass -B.
        local preset=""
        preset="$(_malf_resolve_preset "$subdir")"
        if [[ -n "$preset" ]]; then
            echo "malf commands: configuring $subdir_name ($preset)"
            local cmake_feature_args=()
            mapfile -t cmake_feature_args < <(_malf_cmake_feature_args "$subdir" ON ON)
            cmake --preset "$preset" -S "$subdir" \
                -DCMAKE_EXPORT_COMPILE_COMMANDS=ON \
                "${cmake_feature_args[@]}" 2>&1 | tail -1 || \
                echo "malf commands: warning: cmake configure failed for $subdir_name (continuing)"
        fi
    done

    _malf_merge_db_tree "$build_root" "${db_dirs[@]}"
}

cmd_bench() {
    local subdir="" quick=false filter="" compare=false threshold="0.10" baseline="" extra=()
    local repetitions="" fwd=()
    MALF_CONFIG="Release"
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --compare)   compare=true; fwd+=("$1") ;;
            --threshold) threshold="$2"; fwd+=("$1" "$2"); shift ;;
            --baseline)  baseline="$2"; fwd+=("$1" "$2"); shift ;;
            --repetitions) repetitions="$2"; fwd+=("$1" "$2"); shift ;;
            --quick)     quick=true; fwd+=("$1") ;;
            --filter)    filter="$2"; fwd+=("$1" "$2"); shift ;;
            --debug)     MALF_CONFIG="Debug"; fwd+=("$1") ;;
            --release)   MALF_CONFIG="Release"; fwd+=("$1") ;;
            --profile)   fwd+=("$1" "$2"); shift; _malf_apply_profile "$1" ;;
            --asan)      _malf_apply_profile "$MALF_ASAN_PROFILE"; fwd+=("$1") ;;
            --)          shift; extra+=("$@"); fwd+=(-- "$@"); break ;;
            -*)          extra+=("$1"); fwd+=("$1") ;;
            *)           subdir="$1" ;;
        esac
        shift
    done

    _malf_resolve_target_or_sweep bench "$subdir" "${fwd[@]}"
    local target="$MALF_TARGET"

    _malf_use_keyed_cache

    echo "=== malf bench: $target ($MALF_CONFIG) ==="

    _malf_build_flow "$target"

    if [[ ! -f "$target/CMakeLists.txt" ]]; then
        return 0   # content-only: nothing to run either
    fi
    local build_dir
    build_dir="$(_malf_build_dir "$target")"

    # Find bench executables (*_bench or *bench*)
    local bench_exes=()
    while IFS= read -r exe; do bench_exes+=("$exe"); done < <(
        find "$build_dir" -maxdepth 3 -type f -executable \
            \( -name "*bench*" -o -name "*benchmark*" \) \
            -not -name "*.sh" 2>/dev/null | sort
    )

    if [[ ${#bench_exes[@]} -eq 0 ]]; then
        # In a multi-package sweep a benchless package is normal — skip it.
        # An EXPLICIT `malf bench <pkg>` stays a hard error (you asked for benches).
        if [[ "${MALF_SWEEP:-0}" == "1" ]]; then
            echo "malf bench: no benchmark executables in $(basename "$target") — skipped"
            return 0
        fi
        echo "malf bench: no benchmark executables found in $build_dir" >&2; exit 1
    fi

    local out_dir="$target/bench_results"
    mkdir -p "$out_dir"
    local ts
    ts="$(date +%Y%m%dT%H%M%S)"

    local last_json=""
    for exe in "${bench_exes[@]}"; do
        local name
        name="$(basename "$exe")"
        local out_file="${out_dir}/${name}_${ts}.json"
        local bench_args=(
            "--benchmark_out=${out_file}"
            "--benchmark_out_format=json"
        )
        $quick && bench_args+=("--benchmark_min_time=0.1")
        # The regression gate is variance-aware (bench_compare.py): comparing needs
        # SAMPLES, so --compare defaults to 5 repetitions (median + cv aggregates).
        # A plain `malf bench` stays single-run unless --repetitions is given —
        # but then the baseline it writes carries no cv, so the next compare falls
        # back to the current run's cv alone for the widened threshold.
        local reps="${repetitions:-$($compare && echo 5 || echo 1)}"
        if [[ "$reps" -gt 1 ]]; then
            bench_args+=("--benchmark_repetitions=${reps}"
                         "--benchmark_report_aggregates_only=true")
        fi
        [[ -n "$filter" ]] && bench_args+=("--benchmark_filter=$filter")

        echo "=== malf bench: $name ==="
        "$exe" "${bench_args[@]}" "${extra[@]}"
        echo "Results saved to: $out_file"
        last_json="$out_file"
    done

    # ── update baseline when not comparing ─────────────────────────────────────
    if ! $compare && [[ -n "$last_json" && -f "$last_json" ]]; then
        cp "$last_json" "$out_dir/baseline.json"
        echo "Baseline updated: $out_dir/baseline.json"
    fi

    # ── bench --compare ────────────────────────────────────────────────────────
    if $compare; then
        [[ -z "$baseline" ]] && baseline="$target/bench_results/baseline.json"
        if [[ ! -f "$baseline" ]]; then
            echo "malf bench --compare: error: baseline not found: $baseline" >&2; exit 2
        fi
        if [[ -z "$last_json" || ! -f "$last_json" ]]; then
            echo "malf bench --compare: error: no bench JSON produced" >&2; exit 2
        fi
        echo
        echo "Comparing $last_json vs $baseline (floor ±$(python3 -c "print(${threshold}*100)")%, variance-aware)"
        echo
        python3 "$MALF_DIR/bench_compare.py" "$baseline" "$last_json" "$threshold"
    fi
}

_malf_editables_sync() {
    # Clear the editable registry and re-register every workspace package at the
    # version currently declared in its conanfile.py. `malf build/test` now self-heal
    # stale same-name editables for the deps they touch (see _malf_editable_add), so the
    # normal "bump then build a consumer" cycle no longer needs this. Sync remains the
    # one-shot for the cases the per-build path can't reach: a bumped package that is
    # never built as a dep in a given cache (its stale ref lingers unused), and syncing
    # EVERY keyed cache at once (the per-build path only refreshes the active one).
    # Registration alone fixes resolution — editables build on demand.
    local entries=()
    mapfile -t entries < <(_malf_workspace_packages)
    if [[ ${#entries[@]} -eq 0 ]]; then
        echo "malf editables sync: no workspace packages found under $MALF_WORKSPACE_ROOT" >&2
        exit 1
    fi

    # Sync EVERY cache, not just the active one. malf keys CONAN_HOME per build-type
    # (the base + .conan2/<key> keyed subdirs, each created by _malf_use_keyed_cache);
    # each keyed cache has its OWN editable registry. Syncing only the active cache left
    # the others drifting — e.g. after a 1.x→1.5.0 bump the gcc15-release cache still
    # carried stale 1.4.x editables + a partial 1.5.0 set, so a `--profile linux-gcc15-release`
    # build failed to resolve a freshly-bumped dep. Identify every conan home by its
    # settings.yml (the base + every keyed subdir; excludes the base's own p/ and
    # profiles/ which are not homes). settings.yml is the universal marker — global.conf
    # is malf-seeded and missing on caches created outside malf (e.g. clang21-release).
    local caches=("$MALF_CONAN_HOME_BASE") cache_dir
    for cache_dir in "$MALF_CONAN_HOME_BASE"/*/; do
        [[ -f "${cache_dir}settings.yml" ]] && caches+=("${cache_dir%/}")
    done

    local cache entry ref dep_dir label
    for cache in "${caches[@]}"; do
        export CONAN_HOME="$cache"
        label="${cache#$MALF_CONAN_HOME_BASE}"; label="${label#/}"; [[ -z "$label" ]] && label="base"
        echo "malf editables sync [$label]: re-registering ${#entries[@]} package(s)"
        _malf_editables_clear
        for entry in "${entries[@]}"; do
            IFS=$'\t' read -r ref dep_dir <<< "$entry"
            [[ -n "$ref" && -n "$dep_dir" ]] || continue
            _malf_editable_add "$dep_dir"
        done
    done
    echo "malf editables sync: ${#caches[@]} cache(s) re-registered to ${#entries[@]} editables each"
}

cmd_editables() {
    local sub="${1:-}"
    case "$sub" in
        list)     conan editable list ;;
        sync)     _malf_editables_sync ;;
        "")       echo "malf editables: specify a subcommand (list|sync)" >&2; exit 1 ;;
        *)        echo "malf editables: unknown subcommand '$sub' (list|sync)" >&2; exit 1 ;;
    esac
}

# Regenerate malf/conan.lock by ACCUMULATING every workspace root into one lockfile
# (`conan lock create` chained --lockfile in / --lockfile-out). One file serves every
# profile: measured 2026-07-21, the clang-21 and gcc-15 lockfiles for coderoast_server are
# byte-identical (44 requires / 12 build_requires), because `requires` is profile-independent
# — so per-profile lockfiles would be 9 copies of one fact.
#
# First-party editables land WITHOUT a recipe revision, i.e. they float and are resolved from
# the editable registry, so first-party churn never touches this file. Only third-party is
# pinned — which is the whole point.
#
# By default this locks WHAT WE CURRENTLY BUILD (no --update), so regenerating on a green
# tree is behaviour-neutral and any later red is attributable to the change that caused it.
# `--update` resolves ranges against the REMOTES instead (newest), which is how you take
# upstream movement deliberately — expect a reviewable diff, and re-run the gates.
# Every SBOM the workspace publishes, as "<package dir>|<sbom path>". These are DERIVED
# artifacts (malf/sbom_gen.py projects the resolved conan graph) — the hand-maintained
# predecessor drifted three minors before anyone noticed, and since sbom-cve.yml scans the
# file, its accuracy is the ceiling on our CVE detection.
_MALF_SBOM_TARGETS=(
    "insight-eidos/sift-cli|insight-eidos/sift-cli/sbom.cdx.json"
)

# `malf sbom` regenerates them; `malf sbom --check` fails if one is stale against the graph,
# which is the form a CI/release leg wants.
cmd_sbom() {
    local check="" rc=0 entry pkg out
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --check) check="--check" ;;
            *) echo "malf sbom: unknown option $1 (--check)" >&2; exit 1 ;;
        esac
        shift
    done
    for entry in "${_MALF_SBOM_TARGETS[@]}"; do
        pkg="${entry%%|*}"; out="${entry##*|}"
        python3 "$MALF_DIR/sbom_gen.py" \
            --root "$MALF_WORKSPACE_ROOT/$pkg" \
            --profile "$MALF_PROFILE" \
            --lockfile "$MALF_DIR/conan.lock" \
            --out "$MALF_WORKSPACE_ROOT/$out" \
            ${check:+$check} || rc=1
    done
    return $rc
}

cmd_lock() {
    local update="" root
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --update) update="--update" ;;
            *) echo "malf lock: unknown option $1 (--update)" >&2; exit 1 ;;
        esac
        shift
    done

    local out tmp ok=0 fail=0 failed=()
    out="$MALF_DIR/conan.lock"
    tmp="$(mktemp)"; rm -f "$tmp"

    echo "=== malf lock: accumulating every root${update:+ (--update: resolving ranges from REMOTES)} ==="
    # Reuse the SAME enumeration `editables sync` uses — a second recipe-discovery path here
    # would drift from it the first time a package is added.
    while IFS= read -r root; do
        local args=(--profile:all="$MALF_PROFILE" --lockfile-out="$tmp")
        [[ -f "$tmp" ]] && args+=(--lockfile="$tmp")
        [[ -n "$update" ]] && args+=("$update")
        if conan lock create "$root" "${args[@]}" >/dev/null 2>&1; then
            ok=$((ok + 1)); printf '  ok    %s\n' "${root#"$MALF_WORKSPACE_ROOT"/}"
        else
            fail=$((fail + 1)); failed+=("${root#"$MALF_WORKSPACE_ROOT"/}")
            printf '  FAIL  %s\n' "${root#"$MALF_WORKSPACE_ROOT"/}"
        fi
    done < <(_malf_workspace_packages | cut -f2)

    # A root that fails to resolve is NOT a partial success: its third-party edges would be
    # silently absent from the lockfile, and an absent entry resolves freely — the exact drift
    # the lockfile exists to stop. Refuse to install a lockfile that does not cover the tree.
    if [[ $fail -gt 0 ]]; then
        echo "malf lock: $fail root(s) failed to resolve — lockfile NOT written:" >&2
        printf '  - %s\n' "${failed[@]}" >&2
        rm -f "$tmp"
        return 1
    fi
    mv "$tmp" "$out"
    echo "=== malf lock: $ok root(s) -> $out ==="
    python3 - "$out" <<'PY'
import json, sys
d = json.load(open(sys.argv[1]))
req = d.get("requires", [])
pinned = [r for r in req if "#" in r]
print(f"    requires        {len(req):>3}  ({len(pinned)} third-party pinned, "
      f"{len(req) - len(pinned)} first-party floating)")
print(f"    build_requires  {len(d.get('build_requires', [])):>3}  (all third-party pinned)")
multi = {}
for r in req + d.get("build_requires", []):
    multi.setdefault(r.split("/")[0], set()).add(r.split("#")[0])
multi = {k: sorted(v) for k, v in multi.items() if len(v) > 1}
if multi:
    print("    NOTE — pinned at MULTIPLE versions (two roots disagree; a link-time skew "
          "hazard, not a lockfile error):")
    for k, v in sorted(multi.items()):
        print(f"      {k}: {', '.join(v)}")
PY
}

# Surgically remove STALE first-party conan packages: old-version (and ghost/renamed)
# binaries of CodeRoast-owned packages left in the cache after a coordinated version bump.
# They are INERT for malf builds — editables shadow every first-party ref at the current
# version — but they are disk bloat and a real footgun for any RAW (non-malf) conan call,
# especially the stray ~/.conan2 which has no editables to shadow them. The surgical opposite
# of `clean conan` (which nukes every package dir, third-party included, forcing a full
# from-source rebuild — gcc15 has no ConanCenter binaries). SAFE by construction: removes ONLY
# CodeRoast namespaces (pin_coherence.CODEROAST_PREFIXES — the single source of truth) at a
# version != the uniform workspace baseline; NEVER third-party, NEVER the current version.
# Sweeps every cache `editables sync` touches (base + keyed subdirs) plus the stray default
# home. [[conan-cache-hygiene-multi-home]] [[build-via-malf-editables]].
_malf_clean_stale() {
    # Homes: base + every keyed subdir (settings.yml marker, exactly as editables sync), plus
    # the stray default ~/.conan2 iff it is a real, DISTINCT cache (raw conan ran outside malf).
    local homes=("$MALF_CONAN_HOME_BASE") d
    for d in "$MALF_CONAN_HOME_BASE"/*/; do
        [[ -f "${d}settings.yml" ]] && homes+=("${d%/}")
    done
    if [[ -f "$HOME/.conan2/settings.yml" ]] \
        && [[ "$(realpath "$HOME/.conan2")" != "$(realpath "$MALF_CONAN_HOME_BASE")" ]]; then
        homes+=("$HOME/.conan2")
    fi

    # Read-only planning pass (Python): derive the uniform baseline + owned namespaces from
    # the recipes, list each home, emit "home<TAB>ref" for every stale first-party package.
    # Python only READS (conan list); the conan remove WRITES stay in bash below, visible.
    local plan
    plan="$(python3 - "$MALF_WORKSPACE_ROOT" "${homes[@]}" <<'PY'
import ast, json, os, pathlib, subprocess, sys

ws = pathlib.Path(sys.argv[1]).resolve()
homes = sys.argv[2:]
sys.path.insert(0, str(ws / "scripts"))
from pin_coherence import CODEROAST_PREFIXES   # single source of truth for owned namespaces

# Uniform workspace baseline from the first-party recipes (refuse to guess if non-uniform).
ignore = {".conan2", ".git", ".venv", "node_modules", "test_package"}
def skip(p): return any(x in ignore or x == "build" or x.startswith("build-") for x in p.parts)
versions = set()
for cf in ws.rglob("conanfile.py"):
    if skip(cf):
        continue
    tree = ast.parse(cf.read_text(), filename=str(cf))
    nodes = list(tree.body)
    for item in tree.body:
        if isinstance(item, ast.ClassDef):
            nodes.extend(item.body)
    name = version = None
    for node in nodes:
        if isinstance(node, ast.Assign) and isinstance(node.value, ast.Constant) \
                and isinstance(node.value.value, str):
            for tgt in node.targets:
                if getattr(tgt, "id", None) == "name":
                    name = node.value.value
                elif getattr(tgt, "id", None) == "version":
                    version = node.value.value
    if name and name.startswith(CODEROAST_PREFIXES) and version:
        versions.add(version)
if len(versions) != 1:
    sys.stderr.write(f"malf clean stale: workspace baseline is not uniform "
                     f"({sorted(versions) or 'no first-party recipes found'}) — fix pin coherence "
                     f"(`malf bump` / `malf editables sync`) before pruning stale cache\n")
    sys.exit(2)
baseline = next(iter(versions))
sys.stderr.write(f"malf clean stale: baseline {baseline}; sweeping {len(homes)} cache(s)\n")

for home in homes:
    res = subprocess.run(["conan", "list", "*/*", "--format=json"],
                         env={**os.environ, "CONAN_HOME": home}, capture_output=True, text=True)
    if res.returncode != 0:
        continue
    try:
        refs = json.loads(res.stdout).get("Local Cache", {})
    except json.JSONDecodeError:
        continue
    for ref in refs:
        name, _, version = ref.partition("/")
        if name.startswith(CODEROAST_PREFIXES) and version and version != baseline:
            print(f"{home}\t{ref}")
PY
)" || return 1

    if [[ -z "$plan" ]]; then
        echo "malf clean stale: no stale first-party packages in any cache — already clean."
        return 0
    fi

    local removed=0 failed=0 home ref label
    while IFS=$'\t' read -r home ref; do
        [[ -n "$home" && -n "$ref" ]] || continue
        label="${home#$MALF_CONAN_HOME_BASE}"; label="${label#/}"
        [[ -z "$label" ]] && label="base"
        [[ "$home" == "$HOME/.conan2" ]] && label="stray ~/.conan2"
        if CONAN_HOME="$home" conan remove "$ref" -c >/dev/null 2>&1; then
            echo "  removed  $ref   [$label]"
            removed=$((removed + 1))
        else
            echo "  FAILED   $ref   [$label]" >&2
            failed=$((failed + 1))
        fi
    done <<< "$plan"
    echo "malf clean stale: removed $removed stale first-party ref(s) ($failed failed)"
    [[ $failed -eq 0 ]]
}

# CWD + every member package dir under it — where package-anchored build trees
# (and the repo root's merged clangd DB) live. `clean build` and `run` walk these.
_malf_build_tree_roots() {
    echo "$CWD"
    local _ref _dir
    while IFS=$'\t' read -r _ref _dir; do
        [[ -n "$_dir" && "$_dir" != "$CWD" ]] && echo "$_dir"
    done < <(_malf_member_packages "$CWD")
}

_malf_clean_build_trees() {
    local dir
    while IFS= read -r dir; do
        rm -rf "$dir"/build "$dir"/build-*
    done < <(_malf_build_tree_roots)
}

cmd_clean() {
    local target="${1:-all}"
    case "$target" in
        build)     _malf_clean_build_trees ;;
        conan)     rm -rf "$MALF_CONAN_HOME_BASE"/p "$MALF_CONAN_HOME_BASE"/*/p ;;
        editables) _malf_editables_clear ;;
        stale)     _malf_clean_stale; return $? ;;
        all)       _malf_clean_build_trees && rm -rf "$MALF_CONAN_HOME_BASE"/p "$MALF_CONAN_HOME_BASE"/*/p && _malf_editables_clear ;;
        *)         echo "malf clean: unknown target '$target' (build|conan|editables|stale|all)" >&2; exit 1 ;;
    esac
    echo "malf clean: $target done"
}

cmd_run() {
    local exe_name="${1:-}"
    [[ -n "$exe_name" ]] || { echo "malf run: specify an executable name" >&2; exit 1; }
    local found="" dir
    while IFS= read -r dir; do
        found="$(find "$dir"/build "$dir"/build-* -type f -executable -name "$exe_name" \
            -not -name "*.sh" 2>/dev/null | head -1)"
        [[ -n "$found" ]] && break
    done < <(_malf_build_tree_roots)
    if [[ -z "$found" ]]; then
        echo "malf run: '$exe_name' not found in any package build tree under $CWD" >&2; exit 1
    fi
    echo "malf run: $found"
    exec "$found" "${@:2}"
}

