# clang-tidy is our lexical/style gate; the dynamic sanitizers (ASan/UBSan/TSan) are
# the memory/UB/threading oracle. Two families are therefore OFF in Checks below:
#   -clang-analyzer-*           path-sensitive static analyzer (ON by default): redundant
#                               with the sanitizers, and its notes trace THROUGH third-party
#                               headers (asio/.conan2, libc++) un-filterably, drowning signal.
#   -readability-magic-numbers  twin of the disabled -cppcoreguidelines-avoid-magic-numbers.
#   -readability-redundant-declaration  libc++ re-declares operator new/delete across <new>;
#                               the module GMF (.cppm) surfaces it as locationless noise, no first-party value.
#
# Checks is a YAML LIST, not a folded scalar (`>`): inside a folded scalar a `#` line is
# CONTENT, not a comment — it fused with the next token into one bogus glob and silently
# ate that disable (this had un-disabled -cppcoreguidelines-pro-bounds-avoid-unchecked-
# container-access and -fuchsia-*). List form has real per-line comments. NB: clang-tidy
# accepts list form for Checks but NOT for WarningsAsErrors (string only) — keep it scalar.
#
# Modules: clang-tidy on this codebase REQUIRES fresh, same-major-version clang BMIs —
# build the clang tree first, never lint against a gcc compile DB. See
# technical_docs/operations/modules_tooling.md before touching the lint pipeline.
Checks:
  - bugprone-*
  - performance-*
  - modernize-*
  - readability-*
  - cppcoreguidelines-*
  - -clang-analyzer-*
  - -readability-magic-numbers
  - -readability-redundant-declaration

  # Disabled noisy / conflicting
  - -cppcoreguidelines-pro-bounds-avoid-unchecked-container-access
  - -cppcoreguidelines-pro-bounds-pointer-arithmetic
  - -cppcoreguidelines-pro-bounds-constant-array-index
  - -cppcoreguidelines-avoid-magic-numbers
  - -hicpp-avoid-c-arrays
  - -cppcoreguidelines-avoid-c-arrays
  - -cppcoreguidelines-pro-bounds-array-to-pointer-decay
  - -cppcoreguidelines-pro-type-member-init
  - -modernize-use-trailing-return-type
  - -readability-isolate-declaration
  - -readability-braces-around-statements
  - -google-readability-braces-around-statements
  - -hicpp-braces-around-statements
  - -bugprone-easily-swappable-parameters

  # CRASHES the tool on our module code — not a style choice.
  # cppcoreguidelines-owning-memory reliably SIGSEGVs clang-tidy-21 (then hangs
  # symbolizing its own stack, so a timeout reads as "slow"): its ASTMatcher dies
  # matching a LambdaExpr inside libc++'s <string> that `import std` pulls into every
  # TU's AST (reproduced on fuzz/src/parse_fuzzer.cpp, 2026-07-23). A check that
  # aborts gives ZERO coverage, so disabling it removes nothing. It is also swept in
  # by cppcoreguidelines-* (never deliberately chosen) and near-vacuous here: it needs
  # gsl::owner<> annotations to be meaningful and the workspace has ZERO of them (RAII
  # is enforced, CLAUDE.md). Re-evaluate if a fixed clang-tidy lands AND we adopt owner<>.
  - -cppcoreguidelines-owning-memory

  # NOTE (modules) — misc-* is NOT enabled here, so this does not run today. If you ever
  # allowlist misc-*, disable misc-use-internal-linkage: on named-module code it wrongly
  # pushes a non-exported NAMED-namespace helper (which already has internal MODULE linkage,
  # not TU-local) to TU-local, making inline interface templates that use it ill-formed. This
  # rationale used to live in .clangd's Remove list; it moved here when .clangd was collapsed
  # to inherit this file verbatim (the IDE ⇄ gate parity fix, 2026-07-23).

  # Toolchain / irrelevant ecosystems
  - -fuchsia-*
  - -llvm-*
  - -altera-*
  - -llvmlibc-*
  - -boost-use-ranges

CheckOptions:
  - key: misc-non-private-member-variables-in-classes.PrivateMemberSuffix
    value: '_'

  - key: modernize-use-uniform-initialization.UseAssignment
    value: 'false'

  # Cognitive-complexity bar is DELIBERATELY the default 25 (Founder + Argos policy call,
  # 2026-07-23), made explicit so it is a CHOSEN standard rather than an inherited default,
  # and so there is one place to tune. This is a readability-* check → a warning, NOT in
  # WarningsAsErrors, so it never blocks a build. Handle a finding by TRIAGE, never by raising
  # this number to silence it: a genuinely sprawling function is refactored (single
  # responsibility, root CLAUDE.md); a legitimately-complex algorithmic / hot-path function
  # whose split would fragment a coherent routine gets a SAME-LINE
  # `// NOLINT(readability-function-cognitive-complexity): <reason>` (same-line, per the
  # waiver-anchor-rot rule in logcraft/technical_docs/operations/modules_tooling.md). The bar
  # stays open to revision, but only against DATA: if the finding distribution shows scores
  # inflated by idiomatic macros (LOG/assert one-liners) rather than real control flow, the
  # right lever is `IgnoreMacros: 'true'`, decided against the actual findings — not a raised
  # Threshold, which would silence genuinely-too-complex functions to accommodate a few.
  - key: readability-function-cognitive-complexity.Threshold
    value: '25'

WarningsAsErrors: >
  bugprone-*,
  performance-*,
  cppcoreguidelines-*
